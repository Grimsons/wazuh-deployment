---
# Wazuh Deployment - Vault Variables Example
# This file maps encrypted vault variables to playbook variables
#
# USAGE:
# 1. Run: ./scripts/manage-vault.sh init    (creates vault password)
# 2. Run: ./scripts/manage-vault.sh create  (creates encrypted vault.yml)
# 3. Or manually copy this to vault.yml and encrypt:
#    cp vault.yml.example vault.yml
#    ansible-vault encrypt vault.yml --vault-password-file .vault_password
#
# The encrypted group_vars/vault.yml is automatically loaded by Ansible
# when running playbooks with --vault-password-file .vault_password

# ═══════════════════════════════════════════════════════════════
# Indexer/Dashboard Admin Credentials
# ═══════════════════════════════════════════════════════════════
# Used for:
# - Wazuh Dashboard login (admin user)
# - Wazuh Indexer API authentication
# - Filebeat to Indexer communication
wazuh_indexer_admin_password: "{{ vault_wazuh_indexer_admin_password }}"

# ═══════════════════════════════════════════════════════════════
# Wazuh API Credentials
# ═══════════════════════════════════════════════════════════════
# Used for:
# - Wazuh Manager API authentication
# - Dashboard to Manager API communication
wazuh_api_password: "{{ vault_wazuh_api_password }}"

# ═══════════════════════════════════════════════════════════════
# Agent Enrollment Password
# ═══════════════════════════════════════════════════════════════
# Used for:
# - Agent enrollment with wazuh-authd
# - Secure agent registration
wazuh_agent_enrollment_password: "{{ vault_wazuh_agent_enrollment_password }}"

# ═══════════════════════════════════════════════════════════════
# Manager Cluster Key (Multi-Node Deployments)
# ═══════════════════════════════════════════════════════════════
# Used for:
# - Inter-node authentication in manager clusters
# - Must be identical across all manager nodes
wazuh_manager_cluster_key: "{{ vault_wazuh_manager_cluster_key }}"
