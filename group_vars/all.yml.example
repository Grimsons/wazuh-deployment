---
# Wazuh Ansible Deployment - Group Variables Example
# Copy this file to all.yml and customize for your environment
# Run ./setup.sh to interactively generate this file
# DO NOT commit all.yml - it may contain sensitive data!

# ═══════════════════════════════════════════════════════════════
# General Settings
# ═══════════════════════════════════════════════════════════════
wazuh_version: "4.14.1"
environment_name: "production"
organization_name: "MyOrganization"

# ═══════════════════════════════════════════════════════════════
# Wazuh Indexer Settings
# ═══════════════════════════════════════════════════════════════
wazuh_indexer_cluster_name: "wazuh-cluster"
wazuh_indexer_http_port: 9200
wazuh_indexer_transport_port: 9300
wazuh_indexer_heap_size: "4g"

# Admin password is auto-generated during deployment by default
# Credentials saved to: ./credentials/indexer_admin_password.txt
# To use a custom password, uncomment and set:
# wazuh_indexer_admin_password: "YourSecurePassword"

# Indexer node list for cluster configuration
wazuh_indexer_nodes:
  - name: indexer-1
    ip: 192.168.1.10
  # Add more nodes for cluster:
  # - name: indexer-2
  #   ip: 192.168.1.11
  # - name: indexer-3
  #   ip: 192.168.1.12

# ═══════════════════════════════════════════════════════════════
# Wazuh Manager Settings
# ═══════════════════════════════════════════════════════════════
wazuh_manager_api_port: 55000
wazuh_manager_agent_port: 1514
wazuh_api_user: "wazuh"

# API password is auto-generated during deployment by default
# Credentials saved to: ./credentials/api_password.txt
# To use a custom password, uncomment and set:
# wazuh_api_password: "YourSecurePassword"

# Manager cluster settings (for multi-node deployments)
wazuh_manager_cluster_enabled: false
# wazuh_manager_cluster_name: "wazuh-manager-cluster"
# wazuh_manager_cluster_key: "your-32-char-cluster-key-here!!"

# Manager node list
wazuh_manager_nodes:
  - name: manager-1
    ip: 192.168.1.20
  # Add more nodes for cluster:
  # - name: manager-2
  #   ip: 192.168.1.21

# ═══════════════════════════════════════════════════════════════
# Wazuh Dashboard Settings
# ═══════════════════════════════════════════════════════════════
wazuh_dashboard_port: 443
# Dashboard uses the indexer admin credentials (admin user)
# No separate password configuration needed

# Dashboard node list
wazuh_dashboard_nodes:
  - ip: 192.168.1.30

# ═══════════════════════════════════════════════════════════════
# SSL/TLS Configuration
# ═══════════════════════════════════════════════════════════════

# Local path where certificates are stored (source for Ansible copy)
# Run ./generate-certs.sh to create certificates in this directory
wazuh_certs_path: "files/certs"

# Certificate paths on target hosts (destination)
wazuh_indexer_certs_path: /etc/wazuh-indexer/certs
wazuh_manager_certs_path: /var/ossec/etc/certs
wazuh_dashboard_certs_path: /etc/wazuh-dashboard/certs

# If using your own certificates, place them in files/certs/ with these names:
#   - root-ca.pem, root-ca-key.pem (Root CA)
#   - admin.pem, admin-key.pem (Admin certificate)
#   - indexer-1.pem, indexer-1-key.pem (Indexer certificate, name must match indexer_node_name)
#   - manager-1.pem, manager-1-key.pem (Manager certificate, name must match manager_node_name)
#   - dashboard.pem, dashboard-key.pem (Dashboard certificate)

# ═══════════════════════════════════════════════════════════════
# Security Hardening Settings (PRODUCTION)
# ═══════════════════════════════════════════════════════════════

# IMPORTANT: Set to true for production deployments
# When true, all HTTPS connections verify SSL certificates
# When false, allows self-signed certs without verification (INSECURE)
wazuh_ssl_verify_certificates: true

# TLS Protocol Settings
# Minimum TLS version (TLSv1.2 or TLSv1.3 recommended)
wazuh_tls_minimum_version: "TLSv1.2"

# Strong cipher suites for TLS connections
# These ciphers are PCI-DSS and HIPAA compliant
wazuh_tls_ciphers: "TLS_AES_256_GCM_SHA384:TLS_CHACHA20_POLY1305_SHA256:TLS_AES_128_GCM_SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305"

# Enable hostname verification for inter-node SSL (prevents node spoofing)
wazuh_ssl_verify_hostname: true

# Audit logging - CRITICAL for compliance (PCI-DSS, HIPAA, SOC2)
wazuh_audit_logging_enabled: true
wazuh_audit_log_type: "internal_opensearch"  # or "log4j" for file-based

# Agent enrollment security
# Require password for agent enrollment (recommended for production)
wazuh_authd_use_password: true
# Auto-generated if not specified - saved to credentials/authd_password.txt

# Agent SSL verification
wazuh_authd_ssl_verify_host: true
wazuh_authd_ssl_ciphers: "HIGH:!ADH:!EXP:!MD5:!RC4:!3DES:!CAMELLIA:@STRENGTH"

# Dashboard security
wazuh_dashboard_session_timeout: 60          # minutes
wazuh_dashboard_ssl_verification_mode: "full"  # full, certificate, or none
wazuh_dashboard_cookie_secure: true
wazuh_dashboard_cookie_same_site: "Strict"
wazuh_dashboard_xframe_options: "DENY"
wazuh_dashboard_csp_strict: true

# API security hardening (brute-force protection)
wazuh_api_max_login_attempts: 5              # Lock after N failed attempts
wazuh_api_lockout_time: 900                  # Lockout duration (seconds)
wazuh_api_rate_limit: 100                    # Max requests per minute
wazuh_api_https_only: true                   # Force HTTPS

# Indexer security
wazuh_indexer_ssl_http_enabled: true
wazuh_indexer_anonymous_auth_enabled: false  # Disable anonymous access

# ═══════════════════════════════════════════════════════════════
# Feature Toggles
# ═══════════════════════════════════════════════════════════════
wazuh_vulnerability_detection_enabled: true
wazuh_fim_enabled: true
wazuh_rootkit_detection_enabled: true
wazuh_log_collection_enabled: true
wazuh_active_response_enabled: true

# ═══════════════════════════════════════════════════════════════
# Network/Firewall Settings
# ═══════════════════════════════════════════════════════════════
# Firewall configuration (installs and enables UFW/firewalld if needed)
wazuh_configure_firewall: true

# Network subnets are auto-detected from the host's default interface.
# Uncomment below to override with specific subnets:
# wazuh_allowed_agent_networks:
#   - "10.0.0.0/24"
#   - "192.168.1.0/24"
# wazuh_allowed_cluster_networks:
#   - "10.0.0.0/24"

# SELinux configuration
wazuh_configure_selinux: true

# Package repository settings
wazuh_repo_gpg_key: "https://packages.wazuh.com/key/GPG-KEY-WAZUH"
wazuh_repo_url_apt: "https://packages.wazuh.com/4.x/apt/"
wazuh_repo_url_yum: "https://packages.wazuh.com/4.x/yum/"
