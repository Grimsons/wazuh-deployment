---
# Wazuh Ansible Deployment - Group Variables Example
# Copy this file to all.yml and customize for your environment
# Run ./setup.sh to interactively generate this file
# DO NOT commit all.yml - it may contain sensitive data!

# ═══════════════════════════════════════════════════════════════
# General Settings
# ═══════════════════════════════════════════════════════════════
wazuh_version: "4.14.1"
environment_name: "production"
organization_name: "MyOrganization"

# ═══════════════════════════════════════════════════════════════
# Wazuh Indexer Settings
# ═══════════════════════════════════════════════════════════════
wazuh_indexer_cluster_name: "wazuh-cluster"
wazuh_indexer_http_port: 9200
wazuh_indexer_transport_port: 9300
# JVM heap size: "auto" = 50% of RAM (min 1GB, max 32GB), or specify: "4g", "8g", etc.
wazuh_indexer_heap_size: "auto"

# Admin password is auto-generated during deployment by default
# Credentials saved to: ./credentials/indexer_admin_password.txt
# To use a custom password, uncomment and set:
# wazuh_indexer_admin_password: "YourSecurePassword"

# Indexer node list for cluster configuration
wazuh_indexer_nodes:
  - name: indexer-1
    ip: 192.168.1.10
  # Add more nodes for cluster:
  # - name: indexer-2
  #   ip: 192.168.1.11
  # - name: indexer-3
  #   ip: 192.168.1.12

# Indexer Firewall - Dynamic IP-based access control
# By default, firewall rules are automatically generated from:
#   - wazuh_indexer_nodes (port 9200 + 9300)
#   - wazuh_manager_nodes (port 9200 only)
#   - wazuh_dashboard_nodes (port 9200 only)
#
# To allow additional IPs (e.g., monitoring systems, backup servers):
# wazuh_indexer_additional_allowed_ips:
#   - "10.0.0.100"    # Monitoring server
#   - "10.0.0.101"    # Backup server
#
# To allow additional IPs for transport port (9300) - rarely needed:
# wazuh_indexer_additional_transport_ips:
#   - "10.0.0.102"    # Special indexer node

# ═══════════════════════════════════════════════════════════════
# Wazuh Manager Settings
# ═══════════════════════════════════════════════════════════════
wazuh_manager_api_port: 55000
wazuh_manager_agent_port: 1514
wazuh_api_user: "wazuh"

# API password is auto-generated during deployment by default
# Credentials saved to: ./credentials/api_password.txt
# To use a custom password, uncomment and set:
# wazuh_api_password: "YourSecurePassword"

# Manager cluster settings (for multi-node deployments)
wazuh_manager_cluster_enabled: false
# wazuh_manager_cluster_name: "wazuh-manager-cluster"
# wazuh_manager_cluster_key: "your-32-char-cluster-key-here!!"

# Manager node list
wazuh_manager_nodes:
  - name: manager-1
    ip: 192.168.1.20
  # Add more nodes for cluster:
  # - name: manager-2
  #   ip: 192.168.1.21

# ═══════════════════════════════════════════════════════════════
# Wazuh Dashboard Settings
# ═══════════════════════════════════════════════════════════════
wazuh_dashboard_port: 443
# Dashboard uses the indexer admin credentials (admin user)
# No separate password configuration needed

# Dashboard node list
wazuh_dashboard_nodes:
  - ip: 192.168.1.30

# ═══════════════════════════════════════════════════════════════
# SSL/TLS Configuration
# ═══════════════════════════════════════════════════════════════

# Local path where certificates are stored (source for Ansible copy)
# Run ./generate-certs.sh to create certificates in this directory
wazuh_certs_path: "files/certs"

# Certificate paths on target hosts (destination)
wazuh_indexer_certs_path: /etc/wazuh-indexer/certs
wazuh_manager_certs_path: /var/ossec/etc/certs
wazuh_dashboard_certs_path: /etc/wazuh-dashboard/certs

# If using your own certificates, place them in files/certs/ with these names:
#   - root-ca.pem, root-ca-key.pem (Root CA)
#   - admin.pem, admin-key.pem (Admin certificate)
#   - indexer-1.pem, indexer-1-key.pem (Indexer certificate, name must match indexer_node_name)
#   - manager-1.pem, manager-1-key.pem (Manager certificate, name must match manager_node_name)
#   - dashboard.pem, dashboard-key.pem (Dashboard certificate)

# ═══════════════════════════════════════════════════════════════
# Security Hardening Settings (PRODUCTION)
# ═══════════════════════════════════════════════════════════════

# IMPORTANT: Set to true for production deployments
# When true, all HTTPS connections verify SSL certificates
# When false, allows self-signed certs without verification (INSECURE)
wazuh_ssl_verify_certificates: true

# TLS Protocol Settings
# Minimum TLS version (TLSv1.2 or TLSv1.3 recommended)
wazuh_tls_minimum_version: "TLSv1.2"

# Strong cipher suites for TLS connections
# These ciphers are PCI-DSS and HIPAA compliant
wazuh_tls_ciphers: "TLS_AES_256_GCM_SHA384:TLS_CHACHA20_POLY1305_SHA256:TLS_AES_128_GCM_SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305"

# Enable hostname verification for inter-node SSL (prevents node spoofing)
wazuh_ssl_verify_hostname: true

# Audit logging - CRITICAL for compliance (PCI-DSS, HIPAA, SOC2)
wazuh_audit_logging_enabled: true
wazuh_audit_log_type: "internal_opensearch"  # or "log4j" for file-based

# Agent enrollment security
# Require password for agent enrollment (recommended for production)
wazuh_authd_use_password: true
# Auto-generated if not specified - saved to credentials/authd_password.txt

# Agent SSL verification
wazuh_authd_ssl_verify_host: true
wazuh_authd_ssl_ciphers: "HIGH:!ADH:!EXP:!MD5:!RC4:!3DES:!CAMELLIA:@STRENGTH"

# Dashboard security
wazuh_dashboard_session_timeout: 60          # minutes
wazuh_dashboard_ssl_verification_mode: "full"  # full, certificate, or none
wazuh_dashboard_cookie_secure: true
wazuh_dashboard_cookie_same_site: "Strict"
wazuh_dashboard_xframe_options: "DENY"
wazuh_dashboard_csp_strict: true

# API security hardening (brute-force protection)
wazuh_api_max_login_attempts: 5              # Lock after N failed attempts
wazuh_api_lockout_time: 900                  # Lockout duration (seconds)
wazuh_api_rate_limit: 100                    # Max requests per minute
wazuh_api_https_only: true                   # Force HTTPS

# Indexer security
wazuh_indexer_ssl_http_enabled: true
wazuh_indexer_anonymous_auth_enabled: false  # Disable anonymous access

# ═══════════════════════════════════════════════════════════════
# Feature Toggles
# ═══════════════════════════════════════════════════════════════
wazuh_vulnerability_detection_enabled: true
wazuh_fim_enabled: true
wazuh_rootkit_detection_enabled: true
wazuh_sca_enabled: true                    # Security Configuration Assessment
wazuh_syscollector_enabled: true           # System inventory collection
wazuh_log_collection_enabled: true
wazuh_active_response_enabled: true

# ═══════════════════════════════════════════════════════════════
# Post-Deployment Security
# ═══════════════════════════════════════════════════════════════
# Lock down deployment user after successful deployment
# User can only run unlock script and basic status checks
wazuh_lockdown_deploy_user: true

# ═══════════════════════════════════════════════════════════════
# Email Alerts
# ═══════════════════════════════════════════════════════════════
wazuh_email_notification_enabled: false
# wazuh_email_smtp_server: "smtp.example.com"
# wazuh_email_from: "wazuh@example.com"
# wazuh_email_to: "security@example.com"
# wazuh_email_alert_level: 12

# ═══════════════════════════════════════════════════════════════
# Syslog Output (SIEM Forwarding)
# ═══════════════════════════════════════════════════════════════
wazuh_syslog_output_enabled: false
# wazuh_syslog_output_server: "siem.example.com"
# wazuh_syslog_output_port: 514
# wazuh_syslog_output_format: "json"  # default, json, or cef

# ═══════════════════════════════════════════════════════════════
# Integrations
# ═══════════════════════════════════════════════════════════════

# Slack notifications
# wazuh_integrations:
#   - name: slack
#     hook_url: "https://hooks.slack.com/services/xxx/yyy/zzz"
#     level: 10
#     alert_format: json

# VirusTotal file hash lookups
#   - name: virustotal
#     api_key: "your-virustotal-api-key"
#     level: 7
#     group: "syscheck"

# PagerDuty incident management
#   - name: pagerduty
#     api_key: "your-pagerduty-api-key"
#     level: 12

# ═══════════════════════════════════════════════════════════════
# Container Monitoring
# ═══════════════════════════════════════════════════════════════
wazuh_docker_listener_enabled: false
# wazuh_docker_listener_interval: "10m"

# ═══════════════════════════════════════════════════════════════
# Cloud Integrations
# ═══════════════════════════════════════════════════════════════

# AWS CloudTrail, GuardDuty, VPC Flow Logs
wazuh_aws_enabled: false
# wazuh_aws_buckets:
#   - name: "my-cloudtrail-bucket"
#     type: "cloudtrail"
#     aws_profile: "default"
#     regions:
#       - us-east-1

# Azure Log Analytics
wazuh_azure_enabled: false
# wazuh_azure_log_analytics:
#   - application_id: "your-app-id"
#     application_key: "your-app-key"
#     tenantdomain: "your-tenant.onmicrosoft.com"

# GCP Pub/Sub
wazuh_gcp_enabled: false
# wazuh_gcp_project_id: "my-project"
# wazuh_gcp_subscription_name: "wazuh-subscription"

# Office 365 Audit Logs
wazuh_office365_enabled: false
# wazuh_office365_tenants:
#   - tenant_id: "your-tenant-id"
#     client_id: "your-client-id"
#     client_secret: "your-client-secret"

# GitHub Enterprise Audit Logs
wazuh_github_enabled: false
# wazuh_github_organizations:
#   - name: "my-organization"
#     api_token: "ghp_xxxxxxxxxxxx"

# ═══════════════════════════════════════════════════════════════
# Automatic Index Management (Prevents 1000 Index Limit)
# ═══════════════════════════════════════════════════════════════
# This deployment uses ISM (Index State Management) with automatic
# rollover to prevent reaching OpenSearch's 1000 open index limit.
#
# Key features:
# - Automatic rollover based on size/age/document count
# - Cold indices are CLOSED (don't count toward 1000 limit)
# - Automatic deletion after retention period
# - Write aliases for seamless index transitions

# Enable automatic index rollover (STRONGLY recommended)
wazuh_rollover_enabled: true

# Rollover triggers (any condition triggers new index creation)
wazuh_rollover_max_size: "30gb"            # Rollover when index reaches 30GB
wazuh_rollover_max_age: "1d"               # Rollover daily for predictable naming
wazuh_rollover_max_docs: 50000000          # Rollover at 50 million documents

# Index lifecycle stages
wazuh_retention_enabled: true
wazuh_retention_days: 365                  # Delete after 1 year (adjust for compliance)
wazuh_retention_warm_after_days: 7         # Move to warm tier after 7 days
wazuh_retention_cold_after_days: 30        # Move to cold tier after 30 days

# Close cold indices to prevent reaching 1000 open index limit
# CRITICAL: Closed indices don't count toward the limit!
wazuh_close_cold_indices: true

# Monitoring/Statistics have shorter retention (less critical data)
wazuh_monitoring_retention_days: 7         # Delete monitoring data after 7 days
wazuh_statistics_retention_days: 7         # Delete statistics after 7 days

# Shard configuration (adjust based on cluster size)
wazuh_alerts_primary_shards: 1             # 1 shard recommended for most deployments
wazuh_alerts_replica_shards: 0             # Set > 0 for high availability

# ═══════════════════════════════════════════════════════════════
# Log Rotation
# ═══════════════════════════════════════════════════════════════
wazuh_log_rotation_enabled: true
wazuh_log_rotation_keep_days: 30
wazuh_log_rotation_max_size: "100M"
wazuh_log_rotation_compress: true

# ═══════════════════════════════════════════════════════════════
# Network/Firewall Settings
# ═══════════════════════════════════════════════════════════════
# Firewall configuration (installs and enables UFW/firewalld if needed)
wazuh_configure_firewall: true

# Allow agents from any network (recommended for flexibility)
# When true, firewall allows agent connections (1514, 1515) from anywhere
# When false, only allows from auto-detected or explicitly configured subnets
wazuh_allow_agents_from_any: true

# Network subnets are auto-detected from the host's default interface.
# These settings only apply when wazuh_allow_agents_from_any is false:
# wazuh_allowed_agent_networks:
#   - "10.0.0.0/24"
#   - "192.168.1.0/24"
# wazuh_allowed_cluster_networks:
#   - "10.0.0.0/24"

# SELinux configuration
wazuh_configure_selinux: true

# Package repository settings
wazuh_repo_gpg_key: "https://packages.wazuh.com/key/GPG-KEY-WAZUH"
wazuh_repo_url_apt: "https://packages.wazuh.com/4.x/apt/"
wazuh_repo_url_yum: "https://packages.wazuh.com/4.x/yum/"

# ═══════════════════════════════════════════════════════════════
# Prometheus Monitoring (Optional)
# ═══════════════════════════════════════════════════════════════
# Enable Prometheus exporters for Wazuh metrics
# Deploy with: ansible-playbook site.yml --tags monitoring
wazuh_monitoring_enabled: false

# Indexer (OpenSearch) metrics exporter
wazuh_indexer_exporter_enabled: true
wazuh_indexer_metrics_port: 9114

# Manager API metrics exporter
wazuh_manager_exporter_enabled: true
wazuh_manager_exporter_port: 9115
wazuh_manager_exporter_scrape_interval: 30

# Grafana dashboard provisioning (requires Grafana on dashboard node)
wazuh_grafana_dashboard_enabled: true
wazuh_grafana_provisioning_dir: "/etc/grafana/provisioning/dashboards"

# Alert thresholds for Grafana alerting rules
# wazuh_alert_thresholds:
#   disconnected_agents_warn: 5
#   disconnected_agents_critical: 20
#   disk_usage_warn_percent: 75
#   disk_usage_critical_percent: 90
#   jvm_heap_usage_warn_percent: 80
#   jvm_heap_usage_critical_percent: 95

# Prometheus scrape targets (add to your prometheus.yml):
# scrape_configs:
#   - job_name: 'wazuh-indexer'
#     static_configs:
#       - targets: ['indexer1:9114']
#     scheme: https
#     tls_config:
#       insecure_skip_verify: true
#
#   - job_name: 'wazuh-manager'
#     static_configs:
#       - targets: ['manager1:9115']
