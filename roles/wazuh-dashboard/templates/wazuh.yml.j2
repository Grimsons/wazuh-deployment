# Wazuh App Configuration
# Generated by Ansible
# Documentation: https://documentation.wazuh.com/current/user-manual/wazuh-dashboard/config-file.html

# ═══════════════════════════════════════════════════════════════════════════════
# API Hosts Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Define the Wazuh API endpoints that the dashboard will connect to
hosts:
  - default:
      url: https://{{ wazuh_manager_nodes[0].ip }}
      port: {{ wazuh_manager_api_port }}
      username: "{{ wazuh_api_user }}"
      password: "{{ wazuh_api_password }}"
      run_as: {{ wazuh_dashboard_api_run_as | default(false) | lower }}
{% if wazuh_manager_nodes | length > 1 %}
{% for node in wazuh_manager_nodes[1:] %}
  - {{ node.name }}:
      url: https://{{ node.ip }}
      port: {{ wazuh_manager_api_port }}
      username: "{{ wazuh_api_user }}"
      password: "{{ wazuh_api_password }}"
      run_as: {{ wazuh_dashboard_api_run_as | default(false) | lower }}
{% endfor %}
{% endif %}

# ═══════════════════════════════════════════════════════════════════════════════
# Index Pattern Settings
# ═══════════════════════════════════════════════════════════════════════════════
# Default index pattern for alerts
pattern: {{ wazuh_dashboard_pattern | default('wazuh-alerts-*') }}

# ═══════════════════════════════════════════════════════════════════════════════
# Timeout Settings
# ═══════════════════════════════════════════════════════════════════════════════
# Maximum time (ms) to wait for Wazuh API response
timeout: {{ wazuh_dashboard_api_timeout | default(20000) }}

# ═══════════════════════════════════════════════════════════════════════════════
# API Connection Settings
# ═══════════════════════════════════════════════════════════════════════════════
# Request timeout for API requests in milliseconds
api.timeout: {{ wazuh_dashboard_api_request_timeout | default(20000) }}

# Selector for API (true = show selector, false = use default)
api.selector: {{ wazuh_dashboard_api_selector | default(true) | lower }}

# ═══════════════════════════════════════════════════════════════════════════════
# Alert Sample Settings
# ═══════════════════════════════════════════════════════════════════════════════
# Prefix for sample alert indices
alerts.sample.prefix: {{ wazuh_dashboard_sample_prefix | default('wazuh-alerts-4.x-') }}

# ═══════════════════════════════════════════════════════════════════════════════
# Monitoring Settings
# ═══════════════════════════════════════════════════════════════════════════════
# Enable/disable Wazuh monitoring
wazuh.monitoring.enabled: {{ wazuh_dashboard_monitoring_enabled | default(true) | lower }}

# Monitoring frequency (cron expression)
# Default: every 15 minutes
wazuh.monitoring.frequency: {{ wazuh_dashboard_monitoring_frequency | default(900) }}

# Monitoring index shards
wazuh.monitoring.shards: {{ wazuh_dashboard_monitoring_shards | default(1) }}

# Monitoring index replicas
wazuh.monitoring.replicas: {{ wazuh_dashboard_monitoring_replicas | default(0) }}

# Monitoring index creation interval (h=hourly, d=daily, w=weekly, m=monthly)
wazuh.monitoring.creation: {{ wazuh_dashboard_monitoring_creation | default('w') }}

# Monitoring index pattern
wazuh.monitoring.pattern: {{ wazuh_dashboard_monitoring_pattern | default('wazuh-monitoring-*') }}

# ═══════════════════════════════════════════════════════════════════════════════
# Statistics Settings
# ═══════════════════════════════════════════════════════════════════════════════
# Enable/disable Wazuh statistics
cron.statistics.status: {{ wazuh_dashboard_statistics_enabled | default(true) | lower }}

# Statistics APIs to collect
cron.statistics.apis: {{ wazuh_dashboard_statistics_apis | default([]) | to_json }}

# Statistics index interval (h=hourly, d=daily, w=weekly, m=monthly)
cron.statistics.interval: {{ wazuh_dashboard_statistics_interval | default('0 0 * * * *') }}

# Statistics index name
cron.statistics.index.name: {{ wazuh_dashboard_statistics_index | default('statistics') }}

# Statistics index creation (h=hourly, d=daily, w=weekly, m=monthly)
cron.statistics.index.creation: {{ wazuh_dashboard_statistics_creation | default('w') }}

# Statistics index shards
cron.statistics.shards: {{ wazuh_dashboard_statistics_shards | default(1) }}

# Statistics index replicas
cron.statistics.replicas: {{ wazuh_dashboard_statistics_replicas | default(0) }}

# ═══════════════════════════════════════════════════════════════════════════════
# Health Check Settings
# ═══════════════════════════════════════════════════════════════════════════════
# Enable/disable health checks
checks.pattern: {{ wazuh_dashboard_check_pattern | default(true) | lower }}
checks.template: {{ wazuh_dashboard_check_template | default(true) | lower }}
checks.api: {{ wazuh_dashboard_check_api | default(true) | lower }}
checks.setup: {{ wazuh_dashboard_check_setup | default(true) | lower }}
checks.fields: {{ wazuh_dashboard_check_fields | default(true) | lower }}
checks.metaFields: {{ wazuh_dashboard_check_metafields | default(true) | lower }}
checks.maxBuckets: {{ wazuh_dashboard_check_maxbuckets | default(true) | lower }}
checks.timeFilter: {{ wazuh_dashboard_check_timefilter | default(true) | lower }}

# ═══════════════════════════════════════════════════════════════════════════════
# Agent Enrollment Settings
# ═══════════════════════════════════════════════════════════════════════════════
# DNS/IP for agent enrollment (shown in dashboard)
{% if wazuh_dashboard_enrollment_dns is defined and wazuh_dashboard_enrollment_dns %}
enrollment.dns: {{ wazuh_dashboard_enrollment_dns }}
{% else %}
enrollment.dns: {{ wazuh_manager_nodes[0].ip }}
{% endif %}

# Enrollment password (shown in dashboard for agent registration)
{% if wazuh_authd_use_password | default(true) %}
enrollment.password: "{{ wazuh_agent_enrollment_password | default('') }}"
{% endif %}

# ═══════════════════════════════════════════════════════════════════════════════
# Customization Settings
# ═══════════════════════════════════════════════════════════════════════════════
{% if wazuh_dashboard_custom_logo is defined and wazuh_dashboard_custom_logo %}
# Custom logo (path relative to /usr/share/wazuh-dashboard/plugins/wazuh/public/assets/)
customization.logo.app: {{ wazuh_dashboard_custom_logo }}
{% endif %}

{% if wazuh_dashboard_custom_logo_sidebar is defined and wazuh_dashboard_custom_logo_sidebar %}
customization.logo.sidebar: {{ wazuh_dashboard_custom_logo_sidebar }}
{% endif %}

{% if wazuh_dashboard_custom_logo_healthcheck is defined and wazuh_dashboard_custom_logo_healthcheck %}
customization.logo.healthcheck: {{ wazuh_dashboard_custom_logo_healthcheck }}
{% endif %}

{% if wazuh_dashboard_custom_logo_reports is defined and wazuh_dashboard_custom_logo_reports %}
customization.logo.reports: {{ wazuh_dashboard_custom_logo_reports }}
{% endif %}

# ═══════════════════════════════════════════════════════════════════════════════
# Logging Settings
# ═══════════════════════════════════════════════════════════════════════════════
# Log level: info, debug, error
logs.level: {{ wazuh_dashboard_log_level | default('info') }}

# ═══════════════════════════════════════════════════════════════════════════════
# Hide Manager Alerts
# ═══════════════════════════════════════════════════════════════════════════════
# Hide alerts from the manager itself
hideManagerAlerts: {{ wazuh_dashboard_hide_manager_alerts | default(false) | lower }}

# ═══════════════════════════════════════════════════════════════════════════════
# IP Selector
# ═══════════════════════════════════════════════════════════════════════════════
# Show/hide IP selector on Overview and Agents
ip.selector: {{ wazuh_dashboard_ip_selector | default(true) | lower }}

# Ignore list for IP selector (list of agent IDs to exclude)
ip.ignore: {{ wazuh_dashboard_ip_ignore | default([]) | to_json }}

# ═══════════════════════════════════════════════════════════════════════════════
# Configuration on Demand
# ═══════════════════════════════════════════════════════════════════════════════
# Allow configuration on demand via the dashboard
configuration.ui_api_editable: {{ wazuh_dashboard_ui_api_editable | default(true) | lower }}
