# Wazuh Dashboard Log Rotation
# Generated by Ansible

/var/log/wazuh-dashboard/*.log
/var/log/wazuh-dashboard/*.json
{
    daily
    rotate {{ wazuh_log_rotation_keep_days | default(30) }}
    size {{ wazuh_log_rotation_max_size | default('100M') }}
    missingok
    notifempty
{% if wazuh_log_rotation_compress | default(true) %}
    compress
    delaycompress
{% endif %}
    create 0640 wazuh-dashboard wazuh-dashboard
    sharedscripts
    postrotate
        /bin/systemctl reload wazuh-dashboard > /dev/null 2>&1 || true
    endscript
}
