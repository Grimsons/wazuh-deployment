<!-- Agent configuration for group: {{ item.name }} -->
<!-- Generated by Ansible -->
<!-- {{ item.description | default('No description provided') }} -->

<agent_config{{ ' os="' + item.os + '"' if item.os is defined else '' }}>
{% if item.config.syscheck is defined %}
  <!-- File Integrity Monitoring -->
  <syscheck>
{% if item.config.syscheck.enabled is defined %}
    <disabled>{{ 'no' if item.config.syscheck.enabled else 'yes' }}</disabled>
{% endif %}
{% if item.config.syscheck.frequency is defined %}
    <frequency>{{ item.config.syscheck.frequency }}</frequency>
{% endif %}
{% if item.config.syscheck.scan_on_start is defined %}
    <scan_on_start>{{ 'yes' if item.config.syscheck.scan_on_start else 'no' }}</scan_on_start>
{% endif %}
{% for dir in item.config.syscheck.directories | default([]) %}
    <directories{{ ' realtime="yes"' if dir.realtime | default(false) else '' }}{{ ' report_changes="yes"' if dir.report_changes | default(false) else '' }}{{ ' check_all="yes"' if dir.check_all | default(true) else '' }}{{ ' restrict="' + dir.restrict + '"' if dir.restrict is defined else '' }}>{{ dir.path }}</directories>
{% endfor %}
{% for ignore in item.config.syscheck.ignore | default([]) %}
{% if ignore is mapping %}
    <ignore{{ ' type="' + ignore.type + '"' if ignore.type is defined else '' }}>{{ ignore.path }}</ignore>
{% else %}
    <ignore>{{ ignore }}</ignore>
{% endif %}
{% endfor %}
{% for reg in item.config.syscheck.windows_registry | default([]) %}
    <windows_registry{{ ' arch="' + reg.arch + '"' if reg.arch is defined else '' }}{{ ' tags="' + reg.tags + '"' if reg.tags is defined else '' }}>{{ reg.key }}</windows_registry>
{% endfor %}
{% for reg_ignore in item.config.syscheck.registry_ignore | default([]) %}
{% if reg_ignore is mapping %}
    <registry_ignore{{ ' type="' + reg_ignore.type + '"' if reg_ignore.type is defined else '' }}>{{ reg_ignore.key }}</registry_ignore>
{% else %}
    <registry_ignore>{{ reg_ignore }}</registry_ignore>
{% endif %}
{% endfor %}
  </syscheck>
{% endif %}

{% if item.config.rootcheck is defined %}
  <!-- Rootkit Detection -->
  <rootcheck>
    <disabled>{{ 'no' if item.config.rootcheck.enabled | default(true) else 'yes' }}</disabled>
    <frequency>{{ item.config.rootcheck.frequency | default(43200) }}</frequency>
  </rootcheck>
{% endif %}

{% if item.config.localfile is defined %}
  <!-- Log Collection -->
{% for logfile in item.config.localfile %}
  <localfile>
    <log_format>{{ logfile.format | default('syslog') }}</log_format>
    <location>{{ logfile.location }}</location>
{% if logfile.command is defined %}
    <command>{{ logfile.command }}</command>
{% endif %}
{% if logfile.alias is defined %}
    <alias>{{ logfile.alias }}</alias>
{% endif %}
{% if logfile.frequency is defined %}
    <frequency>{{ logfile.frequency }}</frequency>
{% endif %}
{% if logfile.query is defined %}
    <query>{{ logfile.query }}</query>
{% endif %}
{% if logfile.only_future_events is defined %}
    <only-future-events>{{ 'yes' if logfile.only_future_events else 'no' }}</only-future-events>
{% endif %}
  </localfile>
{% endfor %}
{% endif %}

{% if item.config.wodle is defined %}
  <!-- Wodles (Modules) -->
{% for wodle in item.config.wodle %}
{% if wodle.name == 'syscollector' %}
  <wodle name="syscollector">
    <disabled>{{ 'no' if wodle.enabled | default(true) else 'yes' }}</disabled>
    <interval>{{ wodle.interval | default('1h') }}</interval>
    <scan_on_start>{{ 'yes' if wodle.scan_on_start | default(true) else 'no' }}</scan_on_start>
    <hardware>{{ 'yes' if wodle.hardware | default(true) else 'no' }}</hardware>
    <os>{{ 'yes' if wodle.os | default(true) else 'no' }}</os>
    <network>{{ 'yes' if wodle.network | default(true) else 'no' }}</network>
    <packages>{{ 'yes' if wodle.packages | default(true) else 'no' }}</packages>
    <ports all="{{ 'yes' if wodle.ports_all | default(false) else 'no' }}">{{ 'yes' if wodle.ports | default(true) else 'no' }}</ports>
    <processes>{{ 'yes' if wodle.processes | default(true) else 'no' }}</processes>
{% if wodle.hotfixes is defined %}
    <hotfixes>{{ 'yes' if wodle.hotfixes else 'no' }}</hotfixes>
{% endif %}
  </wodle>
{% elif wodle.name == 'osquery' %}
  <wodle name="osquery">
    <disabled>{{ 'no' if wodle.enabled | default(true) else 'yes' }}</disabled>
    <run_daemon>{{ 'yes' if wodle.run_daemon | default(true) else 'no' }}</run_daemon>
{% if wodle.config_path is defined %}
    <config_path>{{ wodle.config_path }}</config_path>
{% endif %}
    <add_labels>{{ 'yes' if wodle.add_labels | default(true) else 'no' }}</add_labels>
  </wodle>
{% elif wodle.name == 'docker-listener' %}
  <wodle name="docker-listener">
    <disabled>{{ 'no' if wodle.enabled | default(true) else 'yes' }}</disabled>
    <interval>{{ wodle.interval | default('60s') }}</interval>
  </wodle>
{% endif %}
{% endfor %}
{% endif %}

{% if item.config.active_response is defined %}
  <!-- Active Response -->
  <active-response>
    <disabled>{{ 'no' if item.config.active_response.enabled | default(true) else 'yes' }}</disabled>
  </active-response>
{% endif %}

{% if item.config.labels is defined %}
  <!-- Agent Labels -->
  <labels>
{% for label in item.config.labels %}
    <label key="{{ label.key }}">{{ label.value }}</label>
{% endfor %}
  </labels>
{% endif %}

</agent_config>
