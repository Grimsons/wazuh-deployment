# Filebeat Log Rotation
# Generated by Ansible

/var/log/filebeat/filebeat
/var/log/filebeat/*.log
{
    daily
    rotate {{ wazuh_log_rotation_keep_days | default(30) }}
    size {{ wazuh_log_rotation_max_size | default('100M') }}
    missingok
    notifempty
{% if wazuh_log_rotation_compress | default(true) %}
    compress
    delaycompress
{% endif %}
    create 0640 root root
    postrotate
        /bin/systemctl reload filebeat > /dev/null 2>&1 || true
    endscript
}
