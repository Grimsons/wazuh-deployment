# Wazuh API Configuration
# Generated by Ansible

host:
  - {{ wazuh_manager_api_bind_addr | default('0.0.0.0') }}
port: {{ wazuh_manager_api_port | default(55000) }}

# HTTPS Configuration
https:
  enabled: {{ wazuh_manager_api_https | default(true) | lower }}
  key: "server.key"
  cert: "server.crt"
  use_ca: {{ wazuh_manager_api_use_ca | default(false) | lower }}
  ca: "ca.crt"
  ssl_protocol: "{{ wazuh_manager_api_ssl_protocol | default('TLSv1.2') }}"
  ssl_ciphers: "{{ wazuh_manager_api_ssl_ciphers | default('') }}"

# Logging
logs:
  level: "{{ wazuh_manager_api_log_level | default('info') }}"
  format: "{{ wazuh_manager_api_log_format | default('json') }}"

# CORS - Disabled by default for security
cors:
  enabled: {{ wazuh_manager_api_cors_enabled | default(false) | lower }}
  source_route: "{{ wazuh_manager_api_cors_source | default('*') }}"
  expose_headers: "{{ wazuh_manager_api_cors_expose_headers | default('*') }}"
  allow_headers: "{{ wazuh_manager_api_cors_allow_headers | default('*') }}"
  allow_credentials: {{ wazuh_manager_api_cors_credentials | default(false) | lower }}

# Access control - Security hardened defaults
access:
  max_login_attempts: {{ wazuh_manager_api_max_login_attempts | default(5) }}
  block_time: {{ wazuh_manager_api_block_time | default(900) }}
  max_request_per_minute: {{ wazuh_manager_api_max_requests_per_minute | default(100) }}

# Upload configuration - Disabled by default for security
# Enable only if remote command execution is required
upload_configuration:
  remote_commands:
    localfile:
      allow: {{ wazuh_manager_api_allow_remote_localfile | default(false) | lower }}
      exceptions: {{ wazuh_manager_api_remote_localfile_exceptions | default([]) | to_json }}
    wodle_command:
      allow: {{ wazuh_manager_api_allow_remote_wodle | default(false) | lower }}
      exceptions: {{ wazuh_manager_api_remote_wodle_exceptions | default([]) | to_json }}

# Cache settings for performance
cache:
  enabled: {{ wazuh_manager_api_cache_enabled | default(true) | lower }}
  time: {{ wazuh_manager_api_cache_time | default(0.75) }}

# Experimental features
experimental_features: {{ wazuh_manager_api_experimental | default(false) | lower }}
