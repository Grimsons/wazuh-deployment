# Wazuh Manager - Local Internal Options
# Generated by Ansible
#
# These settings tune internal daemon behavior for performance and anti-flooding.
# Only non-default values are included. Wazuh uses built-in defaults for anything
# not specified here.
#
# WARNING: Incorrect values can cause instability. Test changes in non-production first.

{% if wazuh_internal_options is defined and wazuh_internal_options | length > 0 %}
# ── Custom Internal Options ─────────────────────────────────────
{% for option in wazuh_internal_options %}
{{ option.key }}={{ option.value }}
{% endfor %}

{% endif %}
# ── Analysisd (Event Analysis Engine) ───────────────────────────
# Thread count for event processing (default: 0 = auto based on CPU cores)
# Increase if manager CPU is underutilized but event queue is backing up
analysisd.event_threads={{ wazuh_analysisd_event_threads | default(0) }}

# Thread count for rule matching (default: 0 = auto)
analysisd.rule_matching_threads={{ wazuh_analysisd_rule_matching_threads | default(0) }}

# Thread count for FIM database sync (default: 0 = auto)
analysisd.dbsync_threads={{ wazuh_analysisd_dbsync_threads | default(0) }}

# Maximum events in the decode queue before dropping (default: 16384)
# Increase for high-throughput environments to prevent event loss
analysisd.decode_event_queue_size={{ wazuh_analysisd_decode_queue_size | default(16384) }}

# Maximum events in the rule matching queue (default: 16384)
analysisd.process_event_queue_size={{ wazuh_analysisd_process_queue_size | default(16384) }}

# Maximum events in the FIM database sync queue (default: 16384)
analysisd.dbsync_queue_size={{ wazuh_analysisd_dbsync_queue_size | default(16384) }}

# ── Remoted (Agent Communication Daemon) ────────────────────────
# Receive timeout in seconds for agent connections (default: 1)
# Lower values free resources faster from idle connections
remoted.recv_timeout={{ wazuh_remoted_recv_timeout | default(1) }}

# Number of worker threads for handling agent messages (default: 4)
# Increase for deployments with many agents (1 thread per ~250 active agents)
remoted.worker_pool={{ wazuh_remoted_worker_pool | default(4) }}

# ── Logcollector (Manager-side Log Collection) ──────────────────
# Maximum files monitored simultaneously (default: 256)
logcollector.max_files={{ wazuh_logcollector_max_files | default(256) }}

# ── Wazuh DB (Agent State Database) ─────────────────────────────
# Worker threads for database operations (default: 0 = auto)
wazuh_db.worker_pool_size={{ wazuh_db_worker_pool | default(0) }}
