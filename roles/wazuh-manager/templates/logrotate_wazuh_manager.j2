# Wazuh Manager Log Rotation
# Generated by Ansible

/var/ossec/logs/*.log
/var/ossec/logs/*.json
/var/ossec/logs/ossec/*.log
/var/ossec/logs/ossec/*.json
/var/ossec/logs/api/*.log
{
    daily
    rotate {{ wazuh_log_rotation_keep_days | default(30) }}
    size {{ wazuh_log_rotation_max_size | default('100M') }}
    missingok
    notifempty
{% if wazuh_log_rotation_compress | default(true) %}
    compress
    delaycompress
{% endif %}
    create 0640 wazuh wazuh
    sharedscripts
    postrotate
        /bin/systemctl reload wazuh-manager > /dev/null 2>&1 || true
    endscript
}

# Wazuh alerts and archives rotation
/var/ossec/logs/alerts/*.log
/var/ossec/logs/alerts/*.json
/var/ossec/logs/archives/*.log
/var/ossec/logs/archives/*.json
{
    daily
    rotate {{ wazuh_log_rotation_keep_days | default(30) }}
    size {{ wazuh_log_rotation_max_size | default('100M') }}
    missingok
    notifempty
{% if wazuh_log_rotation_compress | default(true) %}
    compress
    delaycompress
{% endif %}
    create 0640 wazuh wazuh
}
