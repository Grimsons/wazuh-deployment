[Unit]
Description=Wazuh Manager Prometheus Exporter
Documentation=https://github.com/wazuh/wazuh
After=network.target wazuh-manager.service
Wants=wazuh-manager.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 {{ wazuh_exporter_install_dir }}/wazuh-manager-exporter.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

# Security hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
ReadOnlyPaths=/

# Resource limits
MemoryMax=256M
CPUQuota=25%

[Install]
WantedBy=multi-user.target
