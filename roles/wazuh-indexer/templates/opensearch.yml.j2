# Wazuh Indexer Configuration
# Generated by Ansible

# Cluster settings
cluster.name: {{ wazuh_indexer_cluster_name }}
node.name: {{ indexer_node_name | default('indexer-1') }}

# Network settings
network.host: {{ wazuh_indexer_network_host | default('0.0.0.0') }}
http.port: {{ wazuh_indexer_http_port }}
transport.port: {{ wazuh_indexer_transport_port }}

# Path settings
path.data: {{ wazuh_indexer_data_path }}
path.logs: {{ wazuh_indexer_log_path }}

# Memory settings - CRITICAL for production
# Prevents JVM from being swapped to disk
bootstrap.memory_lock: {{ wazuh_indexer_memory_lock | default(true) | lower }}

# Discovery settings
discovery.type: {% if wazuh_indexer_nodes | length == 1 %}single-node{% else %}zen{% endif %}

{% if wazuh_indexer_nodes | length > 1 %}
# Cluster discovery
discovery.seed_hosts:
{% for node in wazuh_indexer_nodes %}
  - {{ node.ip }}:{{ wazuh_indexer_transport_port }}
{% endfor %}

cluster.initial_master_nodes:
{% for node in wazuh_indexer_nodes %}
  - {{ node.name }}
{% endfor %}
{% endif %}

# Security settings - Transport layer (inter-node communication)
plugins.security.ssl.transport.pemcert_filepath: certs/indexer.pem
plugins.security.ssl.transport.pemkey_filepath: certs/indexer-key.pem
plugins.security.ssl.transport.pemtrustedcas_filepath: certs/root-ca.pem
plugins.security.ssl.transport.enforce_hostname_verification: {{ wazuh_ssl_verify_hostname | default(true) | lower }}
{% if wazuh_tls_ciphers is defined and wazuh_tls_ciphers %}
plugins.security.ssl.transport.enabled_ciphers:
{% for cipher in wazuh_tls_ciphers.split(':') %}
  - {{ cipher }}
{% endfor %}
{% endif %}
plugins.security.ssl.transport.enabled_protocols:
  - TLSv1.3
  - TLSv1.2

# Security settings - HTTP layer (client connections)
plugins.security.ssl.http.enabled: {{ wazuh_indexer_ssl_http_enabled | default(true) | lower }}
plugins.security.ssl.http.pemcert_filepath: certs/indexer.pem
plugins.security.ssl.http.pemkey_filepath: certs/indexer-key.pem
plugins.security.ssl.http.pemtrustedcas_filepath: certs/root-ca.pem
{% if wazuh_tls_ciphers is defined and wazuh_tls_ciphers %}
plugins.security.ssl.http.enabled_ciphers:
{% for cipher in wazuh_tls_ciphers.split(':') %}
  - {{ cipher }}
{% endfor %}
{% endif %}
plugins.security.ssl.http.enabled_protocols:
  - TLSv1.3
  - TLSv1.2

plugins.security.nodes_dn:
{% for node in wazuh_indexer_nodes %}
  - CN={{ node.name }},OU=Wazuh,O=Wazuh,L=California,ST=California,C=US
{% endfor %}

plugins.security.authcz.admin_dn:
  - CN=admin,OU=Wazuh,O=Wazuh,L=California,ST=California,C=US

plugins.security.allow_unsafe_democertificates: false
plugins.security.allow_default_init_securityindex: true

# Audit logging - CRITICAL for compliance (PCI-DSS, HIPAA, SOC2)
plugins.security.audit.type: {{ wazuh_audit_log_type | default('internal_opensearch') }}
{% if wazuh_audit_logging_enabled | default(true) %}
plugins.security.audit.config.disabled_rest_categories: NONE
plugins.security.audit.config.disabled_transport_categories: NONE
plugins.security.audit.config.log_request_body: true
plugins.security.audit.config.resolve_indices: true
plugins.security.audit.config.resolve_bulk_requests: true
plugins.security.audit.config.enable_rest: true
plugins.security.audit.config.enable_transport: true
{% endif %}

plugins.security.enable_snapshot_restore_privilege: true
plugins.security.check_snapshot_restore_write_privileges: true

plugins.security.restapi.roles_enabled:
  - all_access
  - security_rest_api_access
plugins.security.system_indices.enabled: true
plugins.security.system_indices.indices:
  - .opendistro-alerting-config
  - .opendistro-alerting-alert*
  - .opendistro-anomaly-results*
  - .opendistro-anomaly-detector*
  - .opendistro-anomaly-checkpoints
  - .opendistro-anomaly-detection-state
  - .opendistro-reports-*
  - .opendistro-notifications-*
  - .opendistro-notebooks
  - .opensearch-observability
  - .opendistro-asynchronous-search-response*
  - .replication-metadata-store

# Compatibility mode
compatibility.override_main_response_version: true
