# Wazuh Indexer Log Rotation
# Generated by Ansible

/var/log/wazuh-indexer/*.log
/var/log/wazuh-indexer/*.json
/var/log/wazuh-indexer/gc*.log*
{
    daily
    rotate {{ wazuh_log_rotation_keep_days | default(30) }}
    size {{ wazuh_log_rotation_max_size | default('100M') }}
    missingok
    notifempty
{% if wazuh_log_rotation_compress | default(true) %}
    compress
    delaycompress
{% endif %}
    create 0640 wazuh-indexer wazuh-indexer
    sharedscripts
    postrotate
        # OpenSearch handles its own log rotation internally for some logs
        # This is for additional cleanup
        find /var/log/wazuh-indexer -name "*.log.gz" -mtime +{{ wazuh_log_rotation_keep_days | default(30) }} -delete 2>/dev/null || true
    endscript
}
