<!--
  Wazuh Agent Configuration - macOS
  Generated by Ansible
-->
<ossec_config>
  <client>
{% for node in wazuh_manager_nodes %}
    <server>
      <address>{{ node.ip }}</address>
      <port>{{ wazuh_manager_agent_port | default(1514) }}</port>
      <protocol>{{ wazuh_agent_protocol | default('tcp') }}</protocol>
    </server>
{% endfor %}
    <config-profile>macos, macos{{ ansible_distribution_major_version }}</config-profile>
    <notify_time>{{ wazuh_agent_notify_time | default(10) }}</notify_time>
    <time-reconnect>{{ wazuh_agent_time_reconnect | default(60) }}</time-reconnect>
    <auto_restart>{{ 'yes' if wazuh_agent_auto_restart | default(true) else 'no' }}</auto_restart>
    <crypto_method>aes</crypto_method>
  </client>

  <client_buffer>
    <disabled>no</disabled>
    <queue_size>{{ wazuh_agent_buffer_queue_size | default(5000) }}</queue_size>
    <events_per_second>{{ wazuh_agent_buffer_events_per_second | default(500) }}</events_per_second>
  </client_buffer>

{% if wazuh_agent_labels is defined and wazuh_agent_labels | length > 0 %}
  <!-- Agent Labels - for categorization and filtering -->
  <labels>
{% for label in wazuh_agent_labels %}
    <label key="{{ label.key }}">{{ label.value }}</label>
{% endfor %}
  </labels>
{% elif wazuh_agent_auto_labels | default(true) %}
  <!-- Auto-generated labels from Ansible facts -->
  <labels>
    <label key="os.type">darwin</label>
    <label key="os.family">darwin</label>
    <label key="os.name">macOS</label>
    <label key="os.version">{{ ansible_distribution_version | default('') }}</label>
{% if environment_name is defined %}
    <label key="environment">{{ environment_name }}</label>
{% endif %}
{% if organization_name is defined %}
    <label key="organization">{{ organization_name }}</label>
{% endif %}
{% if wazuh_agent_group is defined %}
    <label key="group">{{ wazuh_agent_group }}</label>
{% endif %}
  </labels>
{% endif %}

{% if wazuh_agent_enrollment_enabled | default(true) %}
  <!-- Agent Enrollment -->
  <enrollment>
    <enabled>yes</enabled>
    <manager_address>{{ wazuh_manager_address | default(wazuh_manager_nodes[0].ip, true) }}</manager_address>
    <port>1515</port>
    <agent_name>{{ ansible_hostname }}</agent_name>
{% if wazuh_authd_use_password | default(true) %}
    <authorization_pass_path>/Library/Ossec/etc/authd.pass</authorization_pass_path>
{% endif %}
    <delay_after_enrollment>{{ wazuh_agent_enrollment_delay | default(30) }}</delay_after_enrollment>
  </enrollment>
{% endif %}

{% if wazuh_agent_fim_enabled | default(true) %}
  <!-- File integrity monitoring -->
  <syscheck>
    <disabled>no</disabled>
    <frequency>{{ wazuh_agent_fim_frequency | default(43200) }}</frequency>
    <scan_on_start>yes</scan_on_start>
    <alert_new_files>yes</alert_new_files>
    <directories check_all="yes" realtime="yes">/etc</directories>
    <directories check_all="yes" realtime="yes">/usr/bin</directories>
    <directories check_all="yes" realtime="yes">/usr/sbin</directories>
    <directories check_all="yes" realtime="yes">/bin</directories>
    <directories check_all="yes" realtime="yes">/sbin</directories>
    <directories check_all="yes" realtime="yes">/usr/local/bin</directories>
    <directories check_all="yes" realtime="yes">/usr/local/sbin</directories>
    <directories check_all="yes" realtime="yes">/Applications</directories>
    <!-- Persistence: Launch Agents/Daemons (T1543.004, T1547.011) -->
    <directories check_all="yes" realtime="yes">/Library/LaunchAgents</directories>
    <directories check_all="yes" realtime="yes">/Library/LaunchDaemons</directories>
    <directories check_all="yes" realtime="yes">/System/Library/LaunchAgents</directories>
    <directories check_all="yes" realtime="yes">/System/Library/LaunchDaemons</directories>
    <!-- User-level persistence -->
    <directories check_all="yes" realtime="yes">/Users/*/Library/LaunchAgents</directories>
    <!-- Privacy/TCC database (T1562 - Impair Defenses) -->
    <directories check_all="yes">/Library/Application Support/com.apple.TCC</directories>
    <!-- Authorization plugins -->
    <directories check_all="yes" realtime="yes">/Library/Security/SecurityAgentPlugins</directories>
    <!-- Login/Logout hooks -->
    <directories check_all="yes" realtime="yes">/private/var/root/Library/Preferences/com.apple.loginwindow.plist</directories>
    <!-- Sudoers -->
    <directories check_all="yes" realtime="yes">/etc/sudoers.d</directories>
    <directories check_all="yes" realtime="yes">/private/etc/sudoers</directories>
    <!-- SSH keys -->
    <directories check_all="yes" realtime="yes">/Users/*/.ssh/authorized_keys</directories>
    <ignore>/etc/hosts.deny</ignore>
    <ignore>/etc/mail/statistics</ignore>
    <skip_nfs>yes</skip_nfs>
    <skip_dev>yes</skip_dev>
    <skip_proc>yes</skip_proc>
    <skip_sys>yes</skip_sys>
  </syscheck>
{% endif %}

{% if wazuh_agent_rootcheck_enabled | default(true) %}
  <!-- Rootcheck -->
  <rootcheck>
    <disabled>no</disabled>
    <check_files>yes</check_files>
    <check_trojans>yes</check_trojans>
    <check_dev>yes</check_dev>
    <check_sys>yes</check_sys>
    <check_pids>yes</check_pids>
    <check_ports>yes</check_ports>
    <check_if>yes</check_if>
    <frequency>{{ wazuh_agent_rootcheck_frequency | default(43200) }}</frequency>
    <rootkit_files>etc/shared/rootkit_files.txt</rootkit_files>
    <rootkit_trojans>etc/shared/rootkit_trojans.txt</rootkit_trojans>
    <skip_nfs>yes</skip_nfs>
  </rootcheck>
{% endif %}

{% if wazuh_agent_log_collection_enabled | default(true) %}
  <!-- Log analysis -->
  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/system.log</location>
  </localfile>

  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/install.log</location>
  </localfile>

  <localfile>
    <log_format>command</log_format>
    <command>log stream --style syslog --predicate 'senderImagePath contains[c] "Santa"' --last 1m 2>/dev/null</command>
    <alias>Santa</alias>
    <frequency>60</frequency>
  </localfile>

  <localfile>
    <log_format>full_command</log_format>
    <command>last -n 20</command>
    <frequency>360</frequency>
  </localfile>

  <!-- Gatekeeper/XProtect events (T1553 - Subvert Trust Controls) -->
  <localfile>
    <log_format>command</log_format>
    <command>log show --style syslog --predicate 'subsystem == "com.apple.ManagedClient" OR subsystem == "com.apple.syspolicy.exec"' --last 5m 2>/dev/null | tail -50</command>
    <alias>gatekeeper_events</alias>
    <frequency>300</frequency>
  </localfile>

  <!-- Authorization and authentication events -->
  <localfile>
    <log_format>command</log_format>
    <command>log show --style syslog --predicate 'category == "authorization" OR subsystem == "com.apple.Authorization"' --last 5m 2>/dev/null | tail -50</command>
    <alias>authorization_events</alias>
    <frequency>300</frequency>
  </localfile>

  <!-- Process execution events -->
  <localfile>
    <log_format>command</log_format>
    <command>log show --style syslog --predicate 'subsystem == "com.apple.endpointsecurity"' --last 5m 2>/dev/null | tail -50</command>
    <alias>endpoint_security</alias>
    <frequency>300</frequency>
  </localfile>

  <!-- Login window / screensaver events -->
  <localfile>
    <log_format>command</log_format>
    <command>log show --style syslog --predicate 'subsystem == "com.apple.loginwindow"' --last 5m 2>/dev/null | tail -50</command>
    <alias>loginwindow_events</alias>
    <frequency>300</frequency>
  </localfile>

  <!-- OpenSSH events -->
  <localfile>
    <log_format>command</log_format>
    <command>log show --style syslog --predicate 'process == "sshd"' --last 5m 2>/dev/null | tail -50</command>
    <alias>sshd_events</alias>
    <frequency>300</frequency>
  </localfile>
{% endif %}

{% if wazuh_agent_syscollector_enabled | default(true) %}
  <!-- System inventory -->
  <wodle name="syscollector">
    <disabled>no</disabled>
    <interval>{{ wazuh_agent_syscollector_interval | default('1h') }}</interval>
    <scan_on_start>yes</scan_on_start>
    <hardware>yes</hardware>
    <os>yes</os>
    <network>yes</network>
    <packages>yes</packages>
    <ports all="no">yes</ports>
    <processes>yes</processes>
  </wodle>
{% endif %}

{% if wazuh_agent_sca_enabled | default(true) %}
  <!-- Security Configuration Assessment -->
  <sca>
    <enabled>yes</enabled>
    <scan_on_start>yes</scan_on_start>
    <interval>12h</interval>
    <skip_nfs>yes</skip_nfs>
  </sca>
{% endif %}

  <!-- Active response -->
  <active-response>
    <disabled>{{ 'yes' if wazuh_agent_active_response_disabled | default(false) else 'no' }}</disabled>
    <ca_store>etc/wpk_root.pem</ca_store>
    <ca_verification>yes</ca_verification>
  </active-response>

  <!-- Anti-flooding: Logcollector rate limiting -->
  <!-- Prevents log collection storms from overwhelming the manager -->
  <logcollector>
    <max_eps>{{ wazuh_agent_logcollector_max_eps | default(500) }}</max_eps>
  </logcollector>

  <!-- Agent log format -->
  <logging>
    <log_format>plain</log_format>
  </logging>

</ossec_config>
