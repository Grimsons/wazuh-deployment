<!--
  Wazuh Agent Configuration
  Generated by Ansible

  Connection mode:
{% if wazuh_lb_enabled | default(false) %}
  LOAD BALANCER — agents connect to the Angie LB at {{ wazuh_lb_address }}.
  The LB distributes connections across all manager nodes transparently.
  To scale or replace manager nodes, only re-run the lb role — agents
  do not need to be reconfigured.
{% else %}
  DIRECT — agents connect to manager nodes directly (multi-server failover).
  When multiple manager nodes are defined in wazuh_manager_nodes, the agent
  will attempt to connect to each server in order. If the primary manager
  becomes unreachable, the agent automatically fails over to the next server.

  To configure failover, define multiple managers in group_vars:
    wazuh_manager_nodes:
      - { name: manager-1, ip: 10.0.0.10 }   # primary
      - { name: manager-2, ip: 10.0.0.11 }   # failover
{% endif %}

  For syslog backup forwarding, configure wazuh_syslog_output_enabled on the
  manager to forward alerts to an external syslog server as a safety net.
-->
<ossec_config>
  <client>
{% if wazuh_lb_enabled | default(false) %}
    <!-- Routing through Angie load balancer: {{ wazuh_lb_address }} -->
    <server>
      <address>{{ wazuh_lb_address }}</address>
      <port>{{ wazuh_lb_agent_port | default(wazuh_manager_agent_port | default(1514)) }}</port>
      <protocol>tcp</protocol>
    </server>
{% else %}
{% for node in wazuh_manager_nodes %}
    <server>
      <address>{{ node.ip }}</address>
      <port>{{ wazuh_manager_agent_port | default(1514) }}</port>
      <protocol>{{ wazuh_agent_protocol | default('tcp') }}</protocol>
    </server>
{% endfor %}
{% endif %}
    <config-profile>{{ ansible_distribution }}, {{ ansible_distribution | lower }}{{ ansible_distribution_major_version }}</config-profile>
    <notify_time>{{ wazuh_agent_notify_time | default(10) }}</notify_time>
    <time-reconnect>{{ wazuh_agent_time_reconnect | default(60) }}</time-reconnect>
    <auto_restart>{{ 'yes' if wazuh_agent_auto_restart | default(true) else 'no' }}</auto_restart>
    <crypto_method>aes</crypto_method>
{% if wazuh_agent_enrollment_enabled | default(true) %}
    <enrollment>
      <enabled>yes</enabled>
{% if wazuh_lb_enabled | default(false) %}
      <!-- Enrollment through Angie load balancer -->
      <manager_address>{{ wazuh_lb_address }}</manager_address>
      <port>{{ wazuh_lb_enrollment_port | default(1515) }}</port>
{% else %}
      <manager_address>{{ wazuh_manager_address | default(wazuh_manager_nodes[0].ip, true) }}</manager_address>
      <port>1515</port>
{% endif %}
      <agent_name>{{ ansible_hostname }}</agent_name>
{% if wazuh_authd_use_password | default(true) %}
      <authorization_pass_path>/var/ossec/etc/authd.pass</authorization_pass_path>
{% endif %}
      <delay_after_enrollment>{{ wazuh_agent_enrollment_delay | default(30) }}</delay_after_enrollment>
    </enrollment>
{% endif %}
  </client>

  <client_buffer>
    <disabled>no</disabled>
    <queue_size>{{ wazuh_agent_buffer_queue_size | default(5000) }}</queue_size>
    <events_per_second>{{ wazuh_agent_buffer_events_per_second | default(500) }}</events_per_second>
  </client_buffer>

{% if wazuh_agent_labels is defined and wazuh_agent_labels | length > 0 %}
  <!-- Agent Labels - for categorization and filtering -->
  <labels>
{% for label in wazuh_agent_labels %}
    <label key="{{ label.key }}">{{ label.value }}</label>
{% endfor %}
  </labels>
{% elif wazuh_agent_auto_labels | default(true) %}
  <!-- Auto-generated labels from Ansible facts -->
  <labels>
    <label key="os.type">{{ ansible_system | lower }}</label>
    <label key="os.family">{{ ansible_os_family | lower }}</label>
    <label key="os.name">{{ ansible_distribution }}</label>
    <label key="os.version">{{ ansible_distribution_version }}</label>
{% if environment_name is defined %}
    <label key="environment">{{ environment_name }}</label>
{% endif %}
{% if organization_name is defined %}
    <label key="organization">{{ organization_name }}</label>
{% endif %}
{% if wazuh_agent_group is defined %}
    <label key="group">{{ wazuh_agent_group }}</label>
{% endif %}
  </labels>
{% endif %}

{% if wazuh_agent_fim_enabled | default(true) %}
  <!-- File integrity monitoring -->
  <syscheck>
    <disabled>no</disabled>
    <frequency>{{ wazuh_agent_fim_frequency | default(43200) }}</frequency>
    <scan_on_start>yes</scan_on_start>
    <alert_new_files>yes</alert_new_files>
{% for directory in wazuh_agent_fim_directories | default(['/etc', '/usr/bin', '/usr/sbin', '/bin', '/sbin', '/boot']) %}
    <directories check_all="yes" realtime="yes">{{ directory }}</directories>
{% endfor %}
{% for directory in wazuh_agent_fim_extra_directories | default([]) %}
    <directories check_all="yes" realtime="yes">{{ directory }}</directories>
{% endfor %}
    <ignore>/etc/mtab</ignore>
    <ignore>/etc/hosts.deny</ignore>
    <ignore>/etc/mail/statistics</ignore>
    <ignore>/etc/random-seed</ignore>
    <ignore>/etc/random.seed</ignore>
    <ignore>/etc/adjtime</ignore>
    <ignore>/etc/httpd/logs</ignore>
    <ignore>/etc/utmpx</ignore>
    <ignore>/etc/wtmpx</ignore>
    <ignore>/etc/cups/certs</ignore>
    <ignore>/etc/dumpdates</ignore>
    <ignore>/etc/svc/volatile</ignore>
    <skip_nfs>yes</skip_nfs>
    <skip_dev>yes</skip_dev>
    <skip_proc>yes</skip_proc>
    <skip_sys>yes</skip_sys>
  </syscheck>
{% endif %}

{% if wazuh_agent_rootcheck_enabled | default(true) %}
  <!-- Rootcheck -->
  <rootcheck>
    <disabled>no</disabled>
    <check_files>yes</check_files>
    <check_trojans>yes</check_trojans>
    <check_dev>yes</check_dev>
    <check_sys>yes</check_sys>
    <check_pids>yes</check_pids>
    <check_ports>yes</check_ports>
    <check_if>yes</check_if>
    <frequency>{{ wazuh_agent_rootcheck_frequency | default(43200) }}</frequency>
    <rootkit_files>etc/shared/rootkit_files.txt</rootkit_files>
    <rootkit_trojans>etc/shared/rootkit_trojans.txt</rootkit_trojans>
    <skip_nfs>yes</skip_nfs>
  </rootcheck>
{% endif %}

{% if wazuh_agent_log_collection_enabled | default(true) %}
  <!-- Log analysis -->
  <localfile>
    <log_format>syslog</log_format>
    <location>/var/ossec/logs/active-responses.log</location>
  </localfile>

{% if ansible_os_family == 'Debian' %}
  <!-- Debian/Ubuntu log files -->
  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/syslog</location>
  </localfile>

  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/auth.log</location>
  </localfile>

  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/dpkg.log</location>
  </localfile>

  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/kern.log</location>
  </localfile>
{% elif ansible_os_family == 'RedHat' %}
  <!-- RHEL/CentOS/Rocky log files -->
  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/messages</location>
  </localfile>

  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/secure</location>
  </localfile>

  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/yum.log</location>
  </localfile>

  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/dnf.log</location>
  </localfile>
{% else %}
  <!-- Generic Linux log files -->
  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/syslog</location>
  </localfile>

  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/messages</location>
  </localfile>

  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/auth.log</location>
  </localfile>

  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/secure</location>
  </localfile>
{% endif %}

  <!-- Common command-based log collection -->
  <localfile>
    <log_format>command</log_format>
    <command>df -P</command>
    <frequency>360</frequency>
  </localfile>

  <localfile>
    <log_format>full_command</log_format>
    <command>netstat -tulpn | sed 's/\([[:alnum:]]\+\)\ \+[[:digit:]]\+\ \+[[:digit:]]\+\ \+\(.*\):\([[:digit:]]*\)\ \+\([0-9.\*]\+\):\(.\*\)\ \+\([[:alpha:]]\+\)\ \+\([[:digit:]]*\/[[:alnum:]\-]\+\).*/\1 \2 == \3 == \4:\5 \6 \7/' | sort -k 4 -g | sed 's/ == \(.*\) ==/:\1/' | sed 1,2d</command>
    <alias>netstat listening ports</alias>
    <frequency>360</frequency>
  </localfile>

  <localfile>
    <log_format>full_command</log_format>
    <command>last -n 20</command>
    <frequency>360</frequency>
  </localfile>

{% if wazuh_agent_auditd_enabled | default(true) %}
  <!-- Auditd log collection (MITRE ATT&CK syscall-level monitoring) -->
  <localfile>
    <log_format>audit</log_format>
    <location>/var/log/audit/audit.log</location>
  </localfile>
{% endif %}
{% endif %}
{% if wazuh_agent_process_monitoring_enabled | default(true) %}
  <!-- Process/Command Monitoring - Detect suspicious activity -->
  <localfile>
    <log_format>full_command</log_format>
    <command>ps auxwww --sort=-%mem | head -20</command>
    <alias>top processes by memory</alias>
    <frequency>{{ wazuh_agent_process_monitoring_interval | default(300) }}</frequency>
  </localfile>

  <localfile>
    <log_format>full_command</log_format>
    <command>ss -tulnp</command>
    <alias>listening sockets</alias>
    <frequency>{{ wazuh_agent_process_monitoring_interval | default(300) }}</frequency>
  </localfile>

  <localfile>
    <log_format>full_command</log_format>
    <command>find /tmp /var/tmp /dev/shm -type f -executable 2>/dev/null | head -20</command>
    <alias>executable files in temp directories</alias>
    <frequency>{{ wazuh_agent_process_monitoring_interval | default(300) }}</frequency>
  </localfile>

  <localfile>
    <log_format>full_command</log_format>
    <command>find /tmp /var/tmp /dev/shm -name ".*" -type f 2>/dev/null | head -20</command>
    <alias>hidden files in temp directories</alias>
    <frequency>{{ wazuh_agent_process_monitoring_interval | default(300) }}</frequency>
  </localfile>
{% endif %}

{% if wazuh_agent_syscollector_enabled | default(true) %}
  <!-- System inventory -->
  <wodle name="syscollector">
    <disabled>no</disabled>
    <interval>{{ wazuh_agent_syscollector_interval | default('1h') }}</interval>
    <scan_on_start>yes</scan_on_start>
    <hardware>yes</hardware>
    <os>yes</os>
    <network>yes</network>
    <packages>yes</packages>
    <ports all="no">yes</ports>
    <processes>yes</processes>
  </wodle>
{% endif %}

{% if wazuh_agent_sca_enabled | default(true) %}
  <!-- Security Configuration Assessment -->
  <sca>
    <enabled>yes</enabled>
    <scan_on_start>yes</scan_on_start>
    <interval>12h</interval>
    <skip_nfs>yes</skip_nfs>
  </sca>
{% endif %}

  <!-- Active response -->
  <active-response>
    <disabled>{{ 'yes' if wazuh_agent_active_response_disabled | default(false) else 'no' }}</disabled>
    <ca_store>etc/wpk_root.pem</ca_store>
    <ca_verification>yes</ca_verification>
  </active-response>

  <!-- Anti-flooding: Logcollector rate limiting -->
  <!-- Prevents log collection storms from overwhelming the manager -->
  <logcollector>
    <max_eps>{{ wazuh_agent_logcollector_max_eps | default(500) }}</max_eps>
  </logcollector>

  <!-- Agent log format -->
  <logging>
    <log_format>plain</log_format>
  </logging>

</ossec_config>
