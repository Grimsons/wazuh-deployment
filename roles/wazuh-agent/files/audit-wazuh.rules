# Wazuh Auditd Rules - MITRE ATT&CK Coverage
# Deployed by Ansible - Do not edit manually
# These rules generate audit events consumed by Wazuh for threat detection

# Remove any existing rules (clean slate)
-D

# Set buffer size (increase for high-volume systems)
-b 8192

# Fail gracefully when buffer is full (0=silent, 1=printk, 2=panic)
-f 1

# ─────────────────────────────────────────────────────────────
# Identity and Access (T1078 - Valid Accounts)
# ─────────────────────────────────────────────────────────────
-w /etc/passwd -p wa -k identity_file_change
-w /etc/shadow -p wa -k identity_file_change
-w /etc/group -p wa -k identity_file_change
-w /etc/gshadow -p wa -k identity_file_change
-w /etc/security/opasswd -p wa -k identity_file_change

# User/group management commands
-w /usr/sbin/useradd -p x -k identity_mgmt
-w /usr/sbin/userdel -p x -k identity_mgmt
-w /usr/sbin/usermod -p x -k identity_mgmt
-w /usr/sbin/groupadd -p x -k identity_mgmt
-w /usr/sbin/groupdel -p x -k identity_mgmt
-w /usr/sbin/groupmod -p x -k identity_mgmt
-w /usr/bin/passwd -p x -k identity_mgmt
-w /usr/bin/chage -p x -k identity_mgmt
-w /usr/sbin/vipw -p x -k identity_mgmt
-w /usr/sbin/vigr -p x -k identity_mgmt

# PAM configuration (T1556 - Modify Authentication Process)
-w /etc/pam.d/ -p wa -k pam_modification
-w /etc/security/limits.conf -p wa -k pam_modification
-w /etc/security/access.conf -p wa -k pam_modification

# SSH configuration (T1098.004 - SSH Authorized Keys)
-w /etc/ssh/sshd_config -p wa -k sshd_config_change
-w /etc/ssh/ssh_config -p wa -k ssh_config_change

# ─────────────────────────────────────────────────────────────
# Privilege Escalation (T1548, T1134)
# ─────────────────────────────────────────────────────────────
-w /etc/sudoers -p wa -k privilege_escalation
-w /etc/sudoers.d/ -p wa -k privilege_escalation
-w /usr/bin/sudo -p x -k privilege_escalation
-w /usr/bin/su -p x -k privilege_escalation

# Setuid/setgid changes (T1548.001 - Setuid and Setgid)
-a always,exit -F arch=b64 -S chmod,fchmod,fchmodat -F auid>=1000 -F auid!=-1 -F key=perm_change
-a always,exit -F arch=b32 -S chmod,fchmod,fchmodat -F auid>=1000 -F auid!=-1 -F key=perm_change

# Ownership changes
-a always,exit -F arch=b64 -S chown,fchown,lchown,fchownat -F auid>=1000 -F auid!=-1 -F key=owner_change
-a always,exit -F arch=b32 -S chown,fchown,lchown,fchownat -F auid>=1000 -F auid!=-1 -F key=owner_change

# ─────────────────────────────────────────────────────────────
# Persistence (T1543 - Create or Modify System Process)
# ─────────────────────────────────────────────────────────────
# Systemd service files
-w /etc/systemd/system/ -p wa -k systemd_service_change
-w /usr/lib/systemd/system/ -p wa -k systemd_service_change
-w /run/systemd/system/ -p wa -k systemd_service_change

# Init scripts
-w /etc/init.d/ -p wa -k init_script_change
-w /etc/rc.local -p wa -k init_script_change

# Cron (T1053.003 - Cron)
-w /etc/crontab -p wa -k cron_change
-w /etc/cron.d/ -p wa -k cron_change
-w /etc/cron.daily/ -p wa -k cron_change
-w /etc/cron.weekly/ -p wa -k cron_change
-w /etc/cron.monthly/ -p wa -k cron_change
-w /etc/cron.hourly/ -p wa -k cron_change
-w /var/spool/cron/ -p wa -k cron_change
-w /var/spool/cron/crontabs/ -p wa -k cron_change

# At jobs (T1053.001 - At)
-w /var/spool/at/ -p wa -k at_change
-w /etc/at.allow -p wa -k at_change
-w /etc/at.deny -p wa -k at_change

# ─────────────────────────────────────────────────────────────
# Kernel Modules (T1547.006 - Kernel Modules and Extensions)
# ─────────────────────────────────────────────────────────────
-a always,exit -F arch=b64 -S init_module,finit_module,delete_module -F key=kernel_module
-a always,exit -F arch=b32 -S init_module,finit_module,delete_module -F key=kernel_module
-w /usr/sbin/insmod -p x -k kernel_module
-w /usr/sbin/rmmod -p x -k kernel_module
-w /usr/sbin/modprobe -p x -k kernel_module
-w /etc/modprobe.d/ -p wa -k kernel_module_config

# ─────────────────────────────────────────────────────────────
# Process Injection/Debugging (T1055 - Process Injection)
# ─────────────────────────────────────────────────────────────
-a always,exit -F arch=b64 -S ptrace -F key=process_injection
-a always,exit -F arch=b32 -S ptrace -F key=process_injection

# ─────────────────────────────────────────────────────────────
# Network Connections (T1071 - Application Layer Protocol)
# ─────────────────────────────────────────────────────────────
-a always,exit -F arch=b64 -S connect -F auid>=1000 -F auid!=-1 -F key=network_connect
-a always,exit -F arch=b32 -S connect -F auid>=1000 -F auid!=-1 -F key=network_connect
-a always,exit -F arch=b64 -S accept,bind,listen -F key=network_listen
-a always,exit -F arch=b32 -S accept,bind,listen -F key=network_listen

# ─────────────────────────────────────────────────────────────
# File System Mounts (T1006 - Direct Volume Access)
# ─────────────────────────────────────────────────────────────
-a always,exit -F arch=b64 -S mount -F auid>=1000 -F auid!=-1 -F key=filesystem_mount
-a always,exit -F arch=b32 -S mount -F auid>=1000 -F auid!=-1 -F key=filesystem_mount

# ─────────────────────────────────────────────────────────────
# Dynamic Linker Hijacking (T1574.006 - LD_PRELOAD)
# ─────────────────────────────────────────────────────────────
-w /etc/ld.so.conf -p wa -k linker_config
-w /etc/ld.so.conf.d/ -p wa -k linker_config
-w /etc/ld.so.preload -p wa -k linker_preload

# ─────────────────────────────────────────────────────────────
# Name Resolution Hijacking (T1565.002)
# ─────────────────────────────────────────────────────────────
-w /etc/hosts -p wa -k hosts_file_change
-w /etc/resolv.conf -p wa -k dns_config_change
-w /etc/nsswitch.conf -p wa -k nsswitch_change

# ─────────────────────────────────────────────────────────────
# Time Manipulation (T1070.006 - Timestomp)
# ─────────────────────────────────────────────────────────────
-a always,exit -F arch=b64 -S adjtimex,settimeofday,clock_settime -F key=time_change
-a always,exit -F arch=b32 -S adjtimex,settimeofday,clock_settime -F key=time_change
-w /etc/localtime -p wa -k time_change

# ─────────────────────────────────────────────────────────────
# Log Tampering (T1070 - Indicator Removal)
# ─────────────────────────────────────────────────────────────
-w /var/log/ -p wa -k log_tampering
-a always,exit -F arch=b64 -S unlink,unlinkat,rename,renameat -F dir=/var/log -F key=log_deletion
-a always,exit -F arch=b32 -S unlink,unlinkat,rename,renameat -F dir=/var/log -F key=log_deletion

# ─────────────────────────────────────────────────────────────
# Container-related Monitoring
# ─────────────────────────────────────────────────────────────
-w /usr/bin/docker -p x -k container_tools
-w /usr/bin/podman -p x -k container_tools
-w /usr/bin/kubectl -p x -k container_tools
-w /usr/bin/crictl -p x -k container_tools

# ─────────────────────────────────────────────────────────────
# Make rules immutable (requires reboot to change)
# Uncomment in high-security environments:
# -e 2
# ─────────────────────────────────────────────────────────────
