# Angie Load Balancer - Main Configuration
# Generated by Ansible — do not edit manually
#
# Dashboard routing mode: {{ 'SSL TERMINATION (company cert on LB)' if wazuh_lb_ssl_termination_enabled | default(false) else 'TCP PASSTHROUGH (TLS end-to-end)' }}
#
# Component routing:
{% if wazuh_lb_ssl_termination_enabled | default(false) %}
#   :{{ wazuh_lb_dashboard_port }}   → Wazuh Dashboard  (HTTP block — company cert → backend re-encrypt)
{% if wazuh_lb_ssl_redirect_http | default(true) %}
#   :{{ wazuh_lb_http_port | default(80) }}    → redirect to :{{ wazuh_lb_dashboard_port }}
{% endif %}
{% else %}
#   :{{ wazuh_lb_dashboard_port }}   → Wazuh Dashboard  (stream block — TCP passthrough)
{% endif %}
#   :{{ wazuh_lb_agent_port }}  → Wazuh Manager   (agent events, TCP passthrough)
#   :{{ wazuh_lb_enrollment_port }}  → Wazuh Manager   (agent enrollment, TCP passthrough)
#   :{{ wazuh_lb_api_port }} → Wazuh Manager   (REST API, TCP passthrough)
{% if wazuh_lb_indexer_enabled | default(false) %}
#   :{{ wazuh_lb_indexer_port }} → Wazuh Indexer   (REST API, TCP passthrough)
{% endif %}

user  angie;
worker_processes  {{ wazuh_lb_worker_processes | default('auto') }};

error_log  {{ wazuh_lb_error_log }} {{ wazuh_lb_error_log_level | default('warn') }};
pid        /run/angie.pid;

events {
    worker_connections  {{ wazuh_lb_worker_connections | default(4096) }};
    use  epoll;
    multi_accept  on;
}

http {
    include       /etc/angie/mime.types;
    default_type  application/octet-stream;

    sendfile        on;
    keepalive_timeout  65;

    # Do not reveal Angie version in error pages or headers
    server_tokens  off;

{% if wazuh_lb_ssl_termination_enabled | default(false) %}
    # WebSocket upgrade map — required for Wazuh Dashboard real-time streaming.
    # Maps the client Upgrade header to the correct backend Connection value.
    map $http_upgrade $connection_upgrade {
        default  upgrade;
        ''       close;
    }

{% endif %}
    # Angie built-in status/metrics endpoint (localhost only)
    server {
        listen  127.0.0.1:8080;
        server_name  localhost;
        access_log  off;

        location /status {
            api /status/;
        }

        location / {
            return 404;
        }
    }

{% if wazuh_lb_ssl_termination_enabled | default(false) %}
    # Dashboard HTTPS + HTTP→HTTPS redirect are in http.d/wazuh-dashboard.conf
    include  /etc/angie/http.d/*.conf;
{% endif %}
}

# Stream block: TCP passthrough for all agent/API/indexer ports
# (and dashboard when SSL termination is disabled)
stream {
    include  /etc/angie/stream.d/*.conf;
}
