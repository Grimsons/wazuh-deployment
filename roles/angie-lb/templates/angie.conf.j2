# Angie Load Balancer - Main Configuration
# Generated by Ansible — do not edit manually
#
# This host acts as a TCP passthrough load balancer for the entire Wazuh stack.
# All TLS is terminated at the actual Wazuh nodes; this host just proxies raw TCP.
#
# Component routing:
#   :{{ wazuh_lb_dashboard_port }}   → Wazuh Dashboard  (HTTPS passthrough)
#   :{{ wazuh_lb_agent_port }}  → Wazuh Manager   (agent events)
#   :{{ wazuh_lb_enrollment_port }}  → Wazuh Manager   (agent enrollment)
#   :{{ wazuh_lb_api_port }} → Wazuh Manager   (REST API, HTTPS passthrough)
{% if wazuh_lb_indexer_enabled | default(false) %}
#   :{{ wazuh_lb_indexer_port }} → Wazuh Indexer   (REST API, HTTPS passthrough)
{% endif %}

user  angie;
worker_processes  {{ wazuh_lb_worker_processes | default('auto') }};

error_log  {{ wazuh_lb_error_log }} {{ wazuh_lb_error_log_level | default('warn') }};
pid        /run/angie.pid;

events {
    worker_connections  {{ wazuh_lb_worker_connections | default(4096) }};
    # Use epoll for best performance on Linux
    use  epoll;
    multi_accept  on;
}

# HTTP block is kept minimal — only used for a status page on localhost
http {
    include       /etc/angie/mime.types;
    default_type  application/octet-stream;

    sendfile        on;
    keepalive_timeout  65;

    # Angie built-in status/metrics endpoint (localhost only)
    server {
        listen  127.0.0.1:8080;
        server_name  localhost;
        access_log  off;

        location /status {
            api /status/;
        }

        location / {
            return 404;
        }
    }
}

# Stream block handles all TCP load balancing for Wazuh
stream {
    include  /etc/angie/stream.d/*.conf;
}
