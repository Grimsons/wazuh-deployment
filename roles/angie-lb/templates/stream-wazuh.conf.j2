# Angie Stream (TCP) Load Balancer — Wazuh Components
# Generated by Ansible — do not edit manually
#
# Cluster topology at deploy time:
#   Indexers  ({{ groups['wazuh_indexers'] | default([]) | length }} node(s)):
{% for host in groups['wazuh_indexers'] | default([]) %}
#     - {{ host }}
{% endfor %}
#
#   Managers  ({{ groups['wazuh_managers'] | default([]) | length }} node(s)):
{% for host in groups['wazuh_managers'] | default([]) %}
#     - {{ host }}
{% endfor %}
#
#   Dashboards ({{ groups['wazuh_dashboards'] | default([]) | length }} node(s)):
{% for host in groups['wazuh_dashboards'] | default([]) %}
#     - {{ host }}
{% endfor %}
#
# Scaling: add nodes to inventory and re-run site.yml --tags lb
# Agents will not need reconfiguration — they always connect to this LB.

# ── Log format for stream ─────────────────────────────────────────────────────
log_format wazuh_stream '$remote_addr [$time_local] '
                        '$protocol $status $bytes_sent $bytes_received '
                        '$session_time "$upstream_addr"';

# ═════════════════════════════════════════════════════════════════════════════
# UPSTREAM: Wazuh Managers — handles agent data, enrollment, and API
# ═════════════════════════════════════════════════════════════════════════════

# Upstream for agent event data (port 1514) and enrollment (port 1515).
# All manager nodes receive agent traffic. With manager clustering enabled,
# any node can accept events from any agent.
upstream wazuh_manager_agents {
    {{ wazuh_lb_algorithm | default('least_conn') }};

{% for host in groups['wazuh_managers'] | default([]) %}
    server {{ host }}:{{ wazuh_manager_agent_port | default(1514) }}
           max_fails={{ wazuh_lb_health_check_fails | default(2) }}
           fail_timeout=30s;
{% endfor %}
}

upstream wazuh_manager_enrollment {
    # Round-robin is fine for short-lived enrollment connections
{% for host in groups['wazuh_managers'] | default([]) %}
    server {{ host }}:1515
           max_fails={{ wazuh_lb_health_check_fails | default(2) }}
           fail_timeout=30s;
{% endfor %}
}

# Upstream for Wazuh REST API (port 55000).
# Dashboard and external API clients hit this.
upstream wazuh_manager_api {
    {{ wazuh_lb_algorithm | default('least_conn') }};

{% for host in groups['wazuh_managers'] | default([]) %}
    server {{ host }}:{{ wazuh_manager_api_port | default(55000) }}
           max_fails={{ wazuh_lb_health_check_fails | default(2) }}
           fail_timeout=30s;
{% endfor %}
}

# ═════════════════════════════════════════════════════════════════════════════
# UPSTREAM: Wazuh Dashboard
# ═════════════════════════════════════════════════════════════════════════════

upstream wazuh_dashboard {
    {{ wazuh_lb_algorithm | default('least_conn') }};

{% for host in groups['wazuh_dashboards'] | default([]) %}
    server {{ host }}:{{ wazuh_dashboard_port | default(443) }}
           max_fails={{ wazuh_lb_health_check_fails | default(2) }}
           fail_timeout=30s;
{% endfor %}
}

{% if wazuh_lb_indexer_enabled | default(false) %}
# ═════════════════════════════════════════════════════════════════════════════
# UPSTREAM: Wazuh Indexer (optional — for external tools)
# ═════════════════════════════════════════════════════════════════════════════

upstream wazuh_indexer {
    {{ wazuh_lb_algorithm | default('least_conn') }};

{% for host in groups['wazuh_indexers'] | default([]) %}
    server {{ host }}:{{ wazuh_indexer_http_port | default(9200) }}
           max_fails={{ wazuh_lb_health_check_fails | default(2) }}
           fail_timeout=30s;
{% endfor %}
}
{% endif %}

# ═════════════════════════════════════════════════════════════════════════════
# SERVER: Agent event data  :{{ wazuh_lb_agent_port }}
# ═════════════════════════════════════════════════════════════════════════════

server {
    listen  {{ wazuh_lb_agent_port | default(1514) }};
    proxy_pass  wazuh_manager_agents;

    # Agent connections are persistent and long-lived
    proxy_connect_timeout  {{ wazuh_lb_connect_timeout | default('10s') }};
    proxy_timeout          {{ wazuh_lb_agent_timeout | default('3600s') }};

    # Enable TCP fast path
    proxy_buffer_size  16k;

    access_log  {{ wazuh_lb_log_dir }}/agent-events.log wazuh_stream;

{% if wazuh_lb_health_checks_enabled | default(true) %}
    # Active health check: probe each manager backend by opening a TCP connection
    health_check interval={{ wazuh_lb_health_check_interval | default(10) }}s
                 fails={{ wazuh_lb_health_check_fails | default(2) }}
                 passes={{ wazuh_lb_health_check_passes | default(1) }};
{% endif %}
}

# ═════════════════════════════════════════════════════════════════════════════
# SERVER: Agent enrollment  :{{ wazuh_lb_enrollment_port }}
# ═════════════════════════════════════════════════════════════════════════════

server {
    listen  {{ wazuh_lb_enrollment_port | default(1515) }};
    proxy_pass  wazuh_manager_enrollment;

    # Enrollment connections are short-lived; a tighter timeout is fine
    proxy_connect_timeout  {{ wazuh_lb_connect_timeout | default('10s') }};
    proxy_timeout          {{ wazuh_lb_api_timeout | default('60s') }};

    access_log  {{ wazuh_lb_log_dir }}/agent-enrollment.log wazuh_stream;

{% if wazuh_lb_health_checks_enabled | default(true) %}
    health_check interval={{ wazuh_lb_health_check_interval | default(10) }}s
                 fails={{ wazuh_lb_health_check_fails | default(2) }}
                 passes={{ wazuh_lb_health_check_passes | default(1) }};
{% endif %}
}

# ═════════════════════════════════════════════════════════════════════════════
# SERVER: Wazuh REST API  :{{ wazuh_lb_api_port }}
# (HTTPS passthrough — TLS terminated at the manager node)
# ═════════════════════════════════════════════════════════════════════════════

server {
    listen  {{ wazuh_lb_api_port | default(55000) }};
    proxy_pass  wazuh_manager_api;

    proxy_connect_timeout  {{ wazuh_lb_connect_timeout | default('10s') }};
    proxy_timeout          {{ wazuh_lb_api_timeout | default('60s') }};

    access_log  {{ wazuh_lb_log_dir }}/manager-api.log wazuh_stream;

{% if wazuh_lb_health_checks_enabled | default(true) %}
    health_check interval={{ wazuh_lb_health_check_interval | default(10) }}s
                 fails={{ wazuh_lb_health_check_fails | default(2) }}
                 passes={{ wazuh_lb_health_check_passes | default(1) }};
{% endif %}
}

# ═════════════════════════════════════════════════════════════════════════════
# SERVER: Wazuh Dashboard  :{{ wazuh_lb_dashboard_port }}
# (HTTPS passthrough — TLS terminated at the dashboard node)
# ═════════════════════════════════════════════════════════════════════════════

server {
    listen  {{ wazuh_lb_dashboard_port | default(443) }};
    proxy_pass  wazuh_dashboard;

    proxy_connect_timeout  {{ wazuh_lb_connect_timeout | default('10s') }};
    proxy_timeout          {{ wazuh_lb_agent_timeout | default('3600s') }};

    access_log  {{ wazuh_lb_log_dir }}/dashboard.log wazuh_stream;

{% if wazuh_lb_health_checks_enabled | default(true) %}
    health_check interval={{ wazuh_lb_health_check_interval | default(10) }}s
                 fails={{ wazuh_lb_health_check_fails | default(2) }}
                 passes={{ wazuh_lb_health_check_passes | default(1) }};
{% endif %}
}

{% if wazuh_lb_indexer_enabled | default(false) %}
# ═════════════════════════════════════════════════════════════════════════════
# SERVER: Wazuh Indexer (optional)  :{{ wazuh_lb_indexer_port }}
# Enable with: wazuh_lb_indexer_enabled: true
# ═════════════════════════════════════════════════════════════════════════════

server {
    listen  {{ wazuh_lb_indexer_port | default(9200) }};
    proxy_pass  wazuh_indexer;

    proxy_connect_timeout  {{ wazuh_lb_connect_timeout | default('10s') }};
    proxy_timeout          {{ wazuh_lb_api_timeout | default('60s') }};

    access_log  {{ wazuh_lb_log_dir }}/indexer.log wazuh_stream;

{% if wazuh_lb_health_checks_enabled | default(true) %}
    health_check interval={{ wazuh_lb_health_check_interval | default(10) }}s
                 fails={{ wazuh_lb_health_check_fails | default(2) }}
                 passes={{ wazuh_lb_health_check_passes | default(1) }};
{% endif %}
}
{% endif %}
