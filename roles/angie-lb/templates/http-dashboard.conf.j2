# Wazuh Dashboard — SSL Termination (company cert) + Backend Re-encryption
# Generated by Ansible — do not edit manually
#
# Flow:
#   Browser ──[TLS: {{ wazuh_lb_ssl_cert_path | basename }}]──► LB :{{ wazuh_lb_dashboard_port }}
#       LB ──[HTTPS, proxy_ssl_verify {{ 'on' if wazuh_lb_backend_ssl_verify | default(false) else 'off' }}]──► Dashboard :{{ wazuh_dashboard_port | default(443) }}
#                                              (self-signed cert accepted by LB)
#
# Dashboard backends ({{ groups['wazuh_dashboards'] | default([]) | length }} node(s)):
{% for host in groups['wazuh_dashboards'] | default([]) %}
#   - {{ host }}:{{ wazuh_dashboard_port | default(443) }}
{% endfor %}

# ── Upstream: Wazuh Dashboard nodes ──────────────────────────────────────────

upstream wazuh_dashboard_https {
    {{ wazuh_lb_algorithm | default('least_conn') }};

{% for host in groups['wazuh_dashboards'] | default([]) %}
    # Keep persistent connections to the dashboard alive.
    # The Wazuh dashboard uses WebSockets which need long-lived connections.
    server {{ host }}:{{ wazuh_dashboard_port | default(443) }};
{% endfor %}

    # Maintain a pool of idle keepalive connections to backends.
    # Reduces TLS handshake overhead for the LB → backend leg.
    keepalive 32;
}

{% if wazuh_lb_ssl_redirect_http | default(true) %}
# ── HTTP → HTTPS redirect (:{{ wazuh_lb_http_port | default(80) }}) ──────────────────────────────────

server {
    listen  {{ wazuh_lb_http_port | default(80) }};
    server_name  _;

    access_log  off;

    # Permanent redirect preserves the request path and query string.
    return 301 https://$host$request_uri;
}
{% endif %}

# ── HTTPS server (:{{ wazuh_lb_dashboard_port }}) with company certificate ──────────────────────

server {
    listen  {{ wazuh_lb_dashboard_port | default(443) }} ssl;
    server_name  _;

    # ── Company certificate (browser-trusted) ────────────────────────────────
    ssl_certificate      {{ wazuh_lb_ssl_cert_path }};
    ssl_certificate_key  {{ wazuh_lb_ssl_key_path }};

    # ── TLS hardening ────────────────────────────────────────────────────────
    ssl_protocols              {{ wazuh_lb_ssl_protocols | default('TLSv1.2 TLSv1.3') }};
    ssl_ciphers                {{ wazuh_lb_ssl_ciphers | default('TLS_AES_256_GCM_SHA384:TLS_CHACHA20_POLY1305_SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384') }};
    ssl_prefer_server_ciphers  {{ 'on' if wazuh_lb_ssl_prefer_server_ciphers | default(true) else 'off' }};

    # ── TLS session cache (improves repeat-connection performance) ───────────
    ssl_session_cache    {{ wazuh_lb_ssl_session_cache | default('shared:SSL:10m') }};
    ssl_session_timeout  {{ wazuh_lb_ssl_session_timeout | default('1d') }};
    ssl_session_tickets  off;  # Disable — forward secrecy

{% if wazuh_lb_ssl_ocsp_stapling | default(false) %}
    # ── OCSP stapling ────────────────────────────────────────────────────────
    ssl_stapling         on;
    ssl_stapling_verify  on;
    ssl_trusted_certificate  {{ wazuh_lb_ssl_trusted_cert_path }};
    resolver  1.1.1.1 8.8.8.8 valid=300s;
    resolver_timeout  5s;
{% endif %}

    # ── Security headers (added at the LB layer) ─────────────────────────────
    # The dashboard already sets most headers; these act as a safety net.
{% if wazuh_lb_ssl_hsts_enabled | default(true) %}
    add_header  Strict-Transport-Security
        "max-age={{ wazuh_lb_ssl_hsts_max_age | default(31536000) }}; includeSubDomains"
        always;
{% endif %}
    add_header  X-Content-Type-Options  "nosniff"  always;
    add_header  X-Frame-Options         "SAMEORIGIN"  always;

    access_log  {{ wazuh_lb_log_dir }}/dashboard.log;
    error_log   {{ wazuh_lb_log_dir }}/dashboard-error.log  {{ wazuh_lb_error_log_level | default('warn') }};

    # ── Proxy to dashboard backends (HTTPS re-encryption) ────────────────────

    location / {
        proxy_pass  https://wazuh_dashboard_https;

        # ── LB → backend TLS settings ──────────────────────────────────────
        proxy_ssl_verify        {{ 'on' if wazuh_lb_backend_ssl_verify | default(false) else 'off' }};
        proxy_ssl_protocols     {{ wazuh_lb_ssl_protocols | default('TLSv1.2 TLSv1.3') }};
{% if wazuh_lb_backend_ssl_verify | default(false) and wazuh_lb_ssl_backend_trusted_cert is defined %}
        proxy_ssl_trusted_certificate  {{ wazuh_lb_ssl_backend_trusted_cert }};
{% endif %}
        # Send SNI to the backend so it presents the right certificate
        proxy_ssl_server_name  on;
        proxy_ssl_name         $proxy_host;
        proxy_ssl_session_reuse  on;

        # ── HTTP version and connection headers ──────────────────────────────
        # HTTP/1.1 required for keepalive and WebSocket support
        proxy_http_version  1.1;

        # WebSocket upgrade passthrough — Wazuh Dashboard uses WebSockets
        # for real-time alert streaming. These headers MUST be forwarded.
        proxy_set_header  Upgrade     $http_upgrade;
        proxy_set_header  Connection  $connection_upgrade;

        # ── Client information forwarding ────────────────────────────────────
        proxy_set_header  Host               $host;
        proxy_set_header  X-Real-IP          $remote_addr;
        proxy_set_header  X-Forwarded-For    $proxy_add_x_forwarded_for;
        proxy_set_header  X-Forwarded-Proto  https;
        proxy_set_header  X-Forwarded-Port   $server_port;

        # ── Timeouts ─────────────────────────────────────────────────────────
        proxy_connect_timeout  {{ wazuh_lb_connect_timeout | default('10s') }};
        # Long read/send timeouts keep WebSocket connections alive
        proxy_read_timeout     {{ wazuh_lb_agent_timeout | default('3600s') }};
        proxy_send_timeout     {{ wazuh_lb_agent_timeout | default('3600s') }};

        # ── Buffering ────────────────────────────────────────────────────────
        # Disable buffering for streaming responses (real-time alerts)
        proxy_buffering  off;

        # ── Health check ─────────────────────────────────────────────────────
{% if wazuh_lb_health_checks_enabled | default(true) %}
        # HTTP health check — Angie probes /app/wazuh on each backend.
        # A 200, 302, or 401 response means the dashboard is up.
        health_check  interval={{ wazuh_lb_health_check_interval | default(10) }}s
                      fails={{ wazuh_lb_health_check_fails | default(2) }}
                      passes={{ wazuh_lb_health_check_passes | default(1) }}
                      uri=/app/wazuh
                      match=dashboard_alive;
{% endif %}
    }
}

{% if wazuh_lb_health_checks_enabled | default(true) %}
# Health check response matcher: 200, 302, or 401 all mean "dashboard is alive".
# 401 = up but not logged in (correct for the /app/wazuh endpoint without a session).
match dashboard_alive {
    status 200 302 401;
}
{% endif %}
