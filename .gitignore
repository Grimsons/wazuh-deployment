# SSH Keys (SENSITIVE - never commit!)
keys/
*.key
*_key
*_key.pub

# Client preparation package (contains SSH public key)
client-prep/
wazuh-client-prep.tar.gz
wazuh-client-prep.sh

# Generated configuration files (may contain passwords)
inventory/hosts.yml
group_vars/all.yml
ansible.cfg

# Generated certificates (keep directory structure, ignore cert files)
files/certs/*.pem
files/certs/*.crt
files/certs/*.csr
files/certs/*.srl
/certs/
*.crt
*.csr
*.srl

# Ansible runtime files
*.retry
.ansible_facts_cache/
/tmp/ansible_facts_cache/

# Ansible vault password file
.vault_pass
.vault_password
vault_password_file

# IDE and Editor files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Logs and temporary files
*.log
logs/
tmp/
temp/
*.tmp
*.bak
*.backup

# Python
__pycache__/
*.py[cod]
*$py.class
venv/
.env
.venv/
